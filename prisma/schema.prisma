// File: prisma/schema.prisma
// Last edited: 2025-11-18 15:10 Europe/London
// Notes:
// - Normalised whitespace (removed non-breaking spaces that can break prisma fmt).
// - Prices/taxes now use @db.Decimal(12,2) for consistent SQL types.
// - Kept your multi-tenant structure. Relation names preserved.
// - Safe defaults; no preview features required.

// ───────────────────────────────────────────────────────────────────────────────
// Generators & Datasource
// ───────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // Explicit binary targets so Prisma doesn't try to fetch a RHEL engine on Vercel
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — runtime
  // Migrations MUST use the direct (unpooled) endpoint: pg_advisory_lock is SESSION-scoped,
  // and through a pooler the lock sticks to an immortal pool connection (2026-07-12 incident:
  // builds blocked ~24h on a lock orphaned this way). Prisma migrate/status read this.
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────────────────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SITE_MANAGER
  STANDARD
}

// Job card lifecycle — stable lowercase keys; translated for display (never shown raw).
// Transitions + per-transition authority live in lib/jobcard-status.ts (the one place).
enum JobCardStatus {
  draft
  quoted
  accepted
  declined
  in_progress
  invoiced
  paid
  done
  cancelled
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

// Invoice lifecycle (bank-style). issued = number assigned, editable. paid_pending = attested
// paid, snapshot FROZEN, reversible in the clearance window, customer told NOTHING yet.
// paid = CONFIRMED by the clearance cron (receipt sent) — true settlement, the income grain.
enum InvoiceStatus {
  issued
  paid_pending
  paid
  settled // warranty terminal state: £0, no charge, closed at issue — never collects, never AR
}

// Chargeable vs warranty invoices draw from SEPARATE counters — both independently gapless.
// A comeback must never burn a chargeable number.
enum InvoiceSeries {
  chargeable
  warranty
}

// Payment-method clearance behaviour: instant = no window (cash in the till); windowed = the
// tenant's clearance window then cron-confirm; manual = pending until explicitly confirmed
// (warranty companies / EMAC — external timescales, never auto-confirmed).
enum PaymentClearance {
  instant
  windowed
  manual
}

// Cost-capture (per-site P&L foundation). Raw cost grains only — no aggregation in-schema.
enum CostType {
  salary // amount_pennies = annual salary
  hourly // amount_pennies = hourly rate
}

enum OverheadPeriod {
  weekly
  monthly
  annual
}

// The GATE projection of the Stripe subscription (cache of Stripe's truth, webhook-written).
// 'lapsed' NOT 'suspended' (ruling 2026-07-13): "suspended" invites barring the door, and barring
// the door bars a garage from its own statutory records. lapsed = READ-ONLY-FOREVER-FREE, never
// locked out. Read only via lib/billing.ts::canWrite — never inline.
enum BillingStatus {
  ok      // trialing or active — full write access
  grace   // past_due: Stripe is retrying; writes still allowed, warned
  lapsed  // canceled / unpaid: reads stay open forever, writes blocked, nothing deleted
}

enum ItemType {
  labour
  part
  misc
  fixed // published fixed-price service bundle (price-led, cost-optional); its own estimate section
}

// Shared, system-defined category for a Profit Centre (typed business unit).
// Cross-site reporting slices by this. Add new values via migration as needed.
enum ProfitCentreCategory {
  repairs
  mot
  spraybooth
  car_sales
}

// Physical unit within a Profit Centre; these become the diary's columns.
enum ResourceType {
  lift
  mot_bay
  spray_booth
}

// ───────────────────────────────────────────────────────────────────────────────
// Core multi-tenant models
// ───────────────────────────────────────────────────────────────────────────────

model Group {
  id               String  @id @default(uuid())
  group_name       String
  trading_name     String?
  company_number   String?
  vat_number       String?
  // Setup-checklist APPLICABILITY declarations (item-13) — NOT "done" flags (completion is always
  // derived from real rows). A sole trader legitimately has no company number and no employees, so
  // these let the owner mark those two signals "not applicable" instead of forever "to do". Scoped
  // to EXACTLY these two signals; resources + financial items are always applicable. Read only via
  // lib/setup-signals.
  employees_not_applicable      Boolean @default(false)
  company_number_not_applicable Boolean @default(false)
  // Master switch: VAT applies anywhere (quotes/invoices/overheads) only when true. Default true
  // preserves existing tenants' VAT-as-now behaviour; sub-threshold garages turn it off. Resolved
  // via lib/tax.ts (getTaxProfile → is_registered) and gated in computeTax — never scattered.
  vat_registered   Boolean @default(true)
  // Company-wide default VAT rate (only meaningful when registered). LEGACY Decimal-percent column,
  // kept in lockstep with tax_default_rate_bp (the canonical integer-basis-point source since the
  // TaxProfile refactor). getTaxProfile reads bp, falling back to ×100 of this while backfill lands.
  default_vat_rate Decimal @default(20) @db.Decimal(5, 2)
  address          String?
  // Marketing attribution captured at signup from a public `?ref=` parameter (DORMANT — no rep
  // system yet; we just never lose the attribution, which is expensive to retrofit). Sanitised +
  // capped at write; null when the signup carried no ref.
  signup_ref       String?

  // ── TaxProfile (item-13 onboarding groundwork). The Group is the LEGAL entity that files one
  // tax return, so tax identity lives here; currency + locale are TRADING identity and stay on Site
  // (a UK group may open a Dublin site — same VAT branch, different rate). Assembled + consumed ONLY
  // via lib/tax.ts::getTaxProfile / computeTax. tax_name is Group.tax_label RELOCATED (one value,
  // seeded from locale_profiles at onboarding — never a third name source). ──
  tax_country_code    String  @default("GB")   // ISO 3166-1 alpha-2
  tax_model           String  @default("vat")  // 'vat' (only live branch) | 'sales_tax' | 'gst_split' (throw NotImplemented)
  tax_default_rate_bp Int?                      // integer BASIS POINTS (2000 = 20%); NULL until backfilled → derive ×100 of default_vat_rate
  prices_include_tax  Boolean @default(false)   // false for UK B2B (line prices are ex-tax)

  // Invoice number DISPLAY format (per-tenant). Rendered via lib/invoice-number.ts::formatInvoiceNumber.
  // FY-prefix is a format string, never a reset. Padding default 4 (Xero-style "0001").
  invoice_prefix            String   @default("")
  invoice_pad_width         Int      @default(4)
  // Fiscal-year DISPLAY segment (e.g. INV-26-0042): 0 = off, 2 or 4 digits of the year the FY
  // started in. The counter underneath stays continuous — FY is formatting, never a reset.
  invoice_fy_digits         Int      @default(0)
  fy_start_month            Int      @default(4) // 1-12; UK default April
  // Warranty-series prefix (comeback £0 invoices) — the filter key for the future comebacks tile.
  invoice_warranty_prefix   String   @default("W")
  // "Sent with GreaseDesk" footer line in invoice EMAILS (never the PDF). Tiering policy later.
  invoice_email_footer      Boolean  @default(true)
  // Bank-style clearance window (hours): mark-paid holds reversible + silent this long before the
  // cron confirms and sends the receipt. Flat window; working-day-aware is a banked refinement.
  paid_confirm_window_hours Int      @default(24)
  // --- Invoicing tab settings (ADMIN; Settings → Invoicing) ---
  invoice_reply_to          String? // business Reply-To on invoice emails (fallback: billing_email)
  invoice_sender_name       String? // display name on the GreaseDesk-owned From (fallback: group_name)
  invoice_footer_text       String? // payment terms / footer block — multi-line, rendered on the document
  invoice_bcc               String? // garage-copy BCC (fallback: billing_email)
  logo_r2_key               String? // tenant logo in R2 ({group}/branding/…), top-centre of the PDF
  // Per-tenant leave-type colour overrides (type→hex; defaults = Okabe–Ito in lib/leave-types;
  // admin-remappable for colour-blind accessibility). Read via resolveLeaveColours only.
  leave_type_colours        Json?
  // Tax LABEL only (admin-typed: VAT/GST/Sales Tax…) — never derived from country; rate stays in Company Details.
  tax_label                 String   @default("VAT")
  billing_email             String   @unique
  is_franchise_grp          Boolean  @default(false)
  created_at                DateTime @default(now())

  // Human-facing, immutable account reference (GB-GD<n>), auto-assigned from a Postgres
  // sequence via a column default (atomic / collision-safe). Never updated by any API.
  ref           String       @unique @default(dbgenerated("('GB-GD' || nextval('group_ref_seq'::regclass))"))
  status        TenantStatus @default(trial) // tenant lifecycle (console-managed later)
  trial_ends_at DateTime? // set on signup to now + TRIAL_DAYS
  // SuperAdmin soft-delete (operator portal). Non-null = ARCHIVED: login blocked (authorize()),
  // hidden from active use, ALL data kept, fully reversible (un-archive clears it). Set only via
  // /api/superadmin/archive — never a tenant-facing action.
  archived_at   DateTime?

  // --- Permission config (per-tenant admin toggles that relax STANDARD authority; default OFF).
  // Resolved via lib/permissions.ts and read inside the permission chokepoints — never scattered.
  perm_standard_edit_pricing  Boolean @default(false)
  perm_standard_diary_entries Boolean @default(false)
  // Diary financial visibility, per role (ADMIN/owner always sees both). see-values = per-block value +
  // "booked" total; see-margin = the margin total (exposes cost structure → tighter defaults).
  perm_manager_see_values     Boolean @default(true)
  perm_manager_see_margin     Boolean @default(false) // margin is a DELIBERATE grant, never inherited (ruling 2026-07-12)
  vin_hint_text               String? // tenant-worded "where to find the VIN" for the phone card; empty = no hint (never a marque default)
  perm_standard_see_values    Boolean @default(false)
  perm_standard_see_margin    Boolean @default(false)
  // Invoices view (AR/debtors surface, amounts included — the permission is binary by design).
  // Managers/admins always; this extends it to STANDARD.
  perm_standard_view_invoices Boolean @default(false)

  billing            GroupBilling?
  features           GroupFeature[]
  sites              Site[]
  roles              Role[]
  users              User[]
  customers          Customer[]
  vehicles           Vehicle[]
  vehicle_identities VehicleIdentity[]
  services           ServiceCatalogue[] // Services at Group level (master list)
  parts              PartCatalogue[]
  tax_rates          TaxRate[]
  promos             Promo[]
  payment_methods    PaymentMethod[]
  audit_logs         AuditLog[]
  bookings           Booking[]
  job_cards          JobCard[]
  diary_notes        DiaryNote[]

  // Cost-capture
  cost_people      CostPerson[]
  overheads        Overhead[]
  cost_allocations CostAllocation[]

  // Invoicing
  invoices         Invoice[]
  invoice_sequence InvoiceSequence?

  // Product catalogue (tenant-level; one shared catalogue across all sites)
  catalogue_items  CatalogueItem[]
  service_tiers    ServiceTier[]
  leaveRecords     LeaveRecord[]
  publicHolidays   PublicHoliday[]
  employmentEvents EmploymentEvent[]
  siteConfigEvents SiteConfigEvent[]
  importBatches    ImportBatch[]
  catalogueAliases CatalogueAlias[]
  lineSplitTemplates LineSplitTemplate[]
}

// Upload failure TELEMETRY (2026-07-14): the technical black-box recorder for the outbox drain —
// {step, status, code, body} for a failed photo/video upload. DELIBERATELY separate from AuditLog:
// the audit trail is the card's BUSINESS record (invoice raised, marked paid, work started) and the
// future Car Owner product surfaces it — a WebKit stack trace has no place there. Nothing technical
// in the ledger, ever. Joined to the card for diagnosis; never rendered to a customer.
model UploadTelemetry {
  id          String   @id @default(uuid())
  group_id    String
  job_card_id String
  photo_id    String
  kind        String
  step        String
  status      Int      @default(0)
  code        String?
  body        String?
  attempts    Int      @default(0)
  created_at  DateTime @default(now())

  @@index([job_card_id, created_at])
  @@index([group_id, created_at])
}

// PLATFORM OPERATOR allowlist (SuperAdmin portal). A user id here can reach /superadmin — this is
// entirely SEPARATE from UserRole (a tenant's ADMIN is NOT an operator; no tenant-role change can
// ever grant this). Resolved only via lib/superadmin::requireSuperAdmin, never getVisibility.
model PlatformOperator {
  user_id    String   @id
  note       String?
  created_at DateTime @default(now())
}

// ── PLATFORM-TIER ACTOR IDENTITIES (layer 1). Operators and Reps are their OWN authenticated
// classes — NOT tenant Users. A rep belongs to no garage; an operator's authority is a different
// axis from tenant authority. Each has its own credentials and its own NextAuth provider; the JWT
// carries actorClass to keep the three boundaries separate. See lib/operator-auth / lib/rep-auth.
enum OperatorRole {
  owner           // all ops; manages operators; ONLY role that purges or transfers ownership
  country_manager // region-scoped; all support + lifecycle except operator-management and purge
  support         // region-scoped, read-only tenant visibility + password reset / change email / extend trial
}

model Operator {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String
  role         OperatorRole @default(support)
  // ISO-3166-1 alpha-2 country codes this operator may act in. IGNORED for `owner` (all regions).
  // The ONLY source of region scope — operatorTenantScope() derives the query filter from here,
  // never from a request param. Empty for a non-owner = can see nothing (fails closed).
  regions      String[]     @default([])
  status       String       @default("active") // 'active' | 'suspended' (authorize() blocks non-active)
  suspended_at DateTime?
  note         String?
  // Set-password invite (mirrors the tenant User flow): raw token emailed, only its hash stored,
  // single-use, 5-day expiry. A new operator is created INVITE_PENDING and cannot log in until set.
  invite_token_hash    String?
  invite_token_expires DateTime?
  invite_token_used_at DateTime?
  last_login_at        DateTime? // stamped by the operator authorize() on successful sign-in
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
}

model Rep {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  ref_code       String   @unique // the `?ref=<code>` marketing token that attributes a signup
  country_code   String   @default("GB")
  payout_details Json?
  status         String   @default("active") // 'active' | 'suspended'
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

// ── COMMISSION ENGINE (layer 2). The money spine: ONE calculation (lib/commission) every surface
// reads. Built entirely dormant (no live payments); every rule is proven synthetically against a
// fixed clock. See lib/commission for the invariants; the fixed-clock plan is the spec.

// Effective-dated rate table. A rate at time T = the LATEST row for (country,currency,tier) with
// effective_from ≤ T (the EmploymentEvent "value-at-T" rule). An amendment is a NEW forward row;
// existing rows are NEVER updated, so historical commission is frozen at the rate in force when the
// payment was collected. Amendable by Platform Owner in the SAP.
model CommissionRate {
  id             String   @id @default(uuid())
  country_code   String // ISO-2 (the tenant's tax_country_code)
  currency       String // ISO-4217 (the collected payment's currency)
  tier           String // 'first_12m' | 'thereafter'
  effective_from DateTime
  amount_pennies Int // flat commission per collected month at this tier, in `currency`
  created_by     String? // operator id (audit)
  created_at     DateTime @default(now())

  // THE TIMELINE INVARIANT, at the database. For a (country, currency, tier) the effective-dated
  // rows form a step function; the engine reads "latest effective_from ≤ collected_at". Two rows
  // sharing an effective_from would make that lookup ambiguous (which rate wins on the boundary
  // day?) — so the boundary point must be unique. This UNIQUE index is that rule made physical:
  // a clean, non-overlapping timeline per key. It also serves the engine's resolveRate lookup
  // (same leading columns), so it replaces the old non-unique index rather than adding to it.
  @@unique([country_code, currency, tier, effective_from])
}

// A JOIN, not a field on the tenant — a garage can attribute to a rep AND a regional manager at
// once, share_bp splitting one payment's commission (active shares sum to 10000). Effective-dated +
// ended_at so a territory hand-over applies the right split per period.
model TenantAttribution {
  id             String    @id @default(uuid())
  group_id       String
  party_type     String // 'rep' | 'operator'
  party_id       String
  role           String // 'referrer' | 'regional'
  share_bp       Int
  effective_from DateTime
  ended_at       DateTime? // null = active; a hand-over sets this (exclusive) as the next takes over (inclusive)
  source         String // 'ref_param' | 'manual' | 'import'
  created_by     String?
  created_at     DateTime  @default(now())

  @@index([group_id])
  @@index([party_type, party_id])
}

// The MATERIALISED ledger — written by the accrual/clawback path on Stripe paid/refund events. Every
// row freezes rate_id + share_bp + tier + currency, so a recompute cross-checks and never moves.
// Idempotency: source_ref = the payment ref (accrual) or refund ref (clawback); unique per party+kind.
model CommissionEntry {
  id             String   @id @default(uuid())
  group_id       String
  party_type     String
  party_id       String
  period         String // 'YYYY-MM' — accrual: the payment's month; clawback: the refund's month
  kind           String // 'accrual' | 'clawback'
  tier           String
  rate_id        String // FROZEN link to the CommissionRate applied
  share_bp       Int
  amount_pennies Int // + accrual, − clawback
  currency       String
  source_ref     String // idempotency key: payment ref (accrual) or refund ref (clawback)
  payment_ref    String // the collected payment this relates to (accrual: itself; clawback: the refunded payment) — netting key
  status         String   @default("pending") // 'pending' | 'paid' | 'void'
  payout_id      String? // set when a payout run pays it; a paid accrual is never mutated by a later clawback
  created_at     DateTime @default(now())

  @@unique([source_ref, party_id, kind]) // a re-delivered webhook is a no-op
  @@index([group_id, period])
  @@index([party_id, status])
  @@index([payment_ref])
}

// PLATFORM audit trail for operator actions (archive/purge). DELIBERATELY its own table, NOT
// AuditLog: AuditLog is group-scoped and cascade-deleted with the tenant, so a purge record can't
// live in the tenant it destroys. This survives the purge — target_name/ref are SNAPSHOTS.
model SuperAdminAudit {
  id                   String   @id @default(uuid())
  operator_user_id     String // the ACTING operator's id
  action               String // 'tenant.archived|unarchived|purged' | 'operator.created|role_changed|regions_changed|suspended|unsuspended'
  // EXTENDED for operator-target actions (this table was tenant-target only). One of target_group_id
  // (tenant actions) or target_operator_id (operator-management actions) is set; the other is null.
  target_group_id      String? // now NULLABLE
  target_operator_id   String? // the operator acted upon
  target_name_snapshot String // tenant name OR operator email — survives even if the row is later changed
  target_ref_snapshot  String?
  reason               String? // required on suspend; free-text where an action takes one
  detail               Json? // before/after (role/regions), purge counts, etc.
  created_at           DateTime @default(now())

  @@index([created_at])
  @@index([target_group_id])
  @@index([target_operator_id])
}

// ── TWO-FACTOR (TOTP). Generic store keyed by (subject_type, subject_id) — deliberately NOT FK'd to
// one identity table, so the SAME mechanism extends to tenant Users and Reps later with NO schema
// change (just a new subject_type). Wired to operators ONLY in this slice. lib/two-factor is the sole
// reader/writer; the TOTP crypto is lib/totp. The secret is a shared secret (base32) stored as-is —
// a DB leak yields the secret but not the password (bcrypt), so 2FA still holds unless BOTH leak;
// encryption-at-rest of the secret is a noted hardening follow-up.
model TwoFactorSecret {
  id           String    @id @default(uuid())
  subject_type String // 'operator' | 'tenant' | 'rep'
  subject_id   String
  secret       String // base32 TOTP secret
  enabled      Boolean   @default(false) // false during enrolment; true ONLY after a confirming code round-trips
  confirmed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@unique([subject_type, subject_id])
}

// One-time recovery codes — the escape hatch when the authenticator device is lost. Raw shown ONCE at
// enrolment; only the sha256 hash is stored (like invite/reset tokens). used_at makes each single-use.
model TwoFactorRecoveryCode {
  id           String    @id @default(uuid())
  subject_type String
  subject_id   String
  code_hash    String // sha256(raw recovery code)
  used_at      DateTime? // set when consumed at login — a used code can never be reused
  created_at   DateTime  @default(now())

  @@index([subject_type, subject_id])
}

// Webhook idempotency ledger (item-12): every Stripe event.id is recorded ONCE before its effect
// is applied; a replay finds the row and is skipped. "A replayed queue that double-logs an hour is
// bad; a replayed charge is worse" — the outbox discipline, higher stakes.
model StripeEvent {
  event_id     String   @id // Stripe event.id — the natural idempotency key
  type         String
  processed_at DateTime @default(now())
}

// Versioned, auditable record of a cookie-consent choice — because a regulator or user may later ask
// "what did they consent to, and when". Anonymous (pre-login, public site): no PII, just the browser's
// stable consent_id (also carried in the gd_consent cookie), the policy version + region in force, and
// the per-category choice. A changed choice writes a NEW row with the same consent_id → the trail is
// the history. Same discipline as the operator audit / rep agreement.
model ConsentEvent {
  id             String   @id @default(uuid())
  consent_id     String // the browser's stable consent uuid (mirrors the gd_consent cookie)
  policy_version String
  region         String
  functional     Boolean
  analytics      Boolean
  marketing      Boolean
  created_at     DateTime @default(now())

  @@index([consent_id])
  @@index([created_at])
}

// THE Content system — one table, two behaviours, legal-grade versioning + a country axis. `legal`
// documents FREEZE an immutable version at publish (acceptance/consent records reference a specific
// version, so a version someone agreed to must never change underneath them — the CommissionRate freeze
// discipline). `page` documents let the LATEST published version win; priors are kept only for undo.
// The types differ by RULE at publish time, not by architecture: history never moves for either — you
// never mutate a published row, you publish a NEW version. Keyed on (slug, country, version): the same
// slug can have GB and IE variants; resolution is exact-country → GB fallback, latest published_at wins.
// `version` is a STRING stamp (e.g. '2026-07-21') so an existing consent record resolves to a real
// version; the sentinel 'draft' marks the single work-in-progress row (the unique index enforces one
// draft per slug+country). Body is markdown, rendered SAFELY (no raw HTML). Media/scheduling/SEO later.
model Document {
  id             String    @id @default(uuid())
  slug           String
  title          String
  type           String // 'legal' | 'page'
  country_code   String    @default("GB")
  body           String // markdown
  version        String // published: a stamp like '2026-07-21'; WIP draft: the sentinel 'draft'
  status         String    @default("draft") // 'draft' | 'published'
  effective_from DateTime?
  published_at   DateTime?
  created_by     String? // operator id
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@unique([slug, country_code, version])
  @@index([slug, country_code, status])
}

model GroupBilling {
  id               String        @id @default(uuid())
  group_id         String        @unique
  plan_name        String
  status           BillingStatus
  retention_months Int
  included_sites   Int
  active_sites_cnt Int           @default(1)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now())

  // ── Stripe CACHE (item-12). Stripe is the source of truth; these four are a mirror written ONLY
  // by verified webhook handlers (lib/stripe-webhook). subscription_status is the raw Stripe status
  // (trialing/active/past_due/canceled/…) that lib/billing derives the gate + the display status
  // from. NULL until the tenant completes Checkout. Never write these from a redirect. ──
  stripe_customer_id     String?  @unique
  stripe_subscription_id String?  @unique
  subscription_status    String? // raw Stripe subscription.status
  current_period_end     DateTime? // Stripe's period end (renewal/charge date), webhook-maintained

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
}

model GroupFeature {
  id          String  @id @default(uuid())
  group_id    String
  feature_key String
  enabled     Boolean @default(false)

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, feature_key])
}

model Site {
  id             String   @id @default(uuid())
  group_id       String
  site_name      String
  trading_name   String?
  company_number String?
  vat_number     String?
  address        String?
  phone          String?
  email          String?
  timezone       String   @default("Europe/London")
  currency_code  String   @default("GBP")
  locale         String   @default("en-GB")
  is_franchise   Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  // --- NEW CONFIGURATION FIELDS ---
  pricing_display_mode String @default("ex_vat") // Ex VAT/Inc VAT display
  supported_countries  Json?
  supported_currencies Json?
  // --- DIARY DISPLAY (per-site) ---
  open_days            Int[]  @default([1, 2, 3, 4, 5, 6]) // weekdays open (0=Sun..6=Sat); default Mon–Sat
  open_hour            Int    @default(8) // diary window start hour
  close_hour           Int    @default(18) // diary window end hour
  week_start           Int    @default(1) // first day of week (0=Sun, 1=Mon)
  // Booking-form duration granularity (minutes) for the Quote-tab slot picker. Sub-day durations step
  // by this; working-day length comes from open_hour/close_hour. Default 30. Diary reads start_at/end_at.
  booking_slot_minutes Int    @default(30)
  // Non-working bands (lunch etc.) as [{start,end}] minutes-from-midnight. NULL/[] = none = current
  // behaviour. The footprint skips these; the diary draws them. Read via lib/occupancy parseBreaks.
  breaks               Json?
  // --------------------------------

  group            Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  features         SiteFeature[]
  profit_centres   ProfitCentre[]
  resources        Resource[]
  users            User[]
  user_assignments UserSite[]
  customers        Customer[]
  bookings         Booking[]
  job_cards        JobCard[]
  services         ServiceCatalogue[]
  diary_notes      DiaryNote[]
  cost_allocations CostAllocation[]
  invoices         Invoice[]
  leaveRecords     LeaveRecord[]
  publicHolidays   PublicHoliday[]

  @@index([group_id])
  config_events SiteConfigEvent[]
  import_batches ImportBatch[]
}

model SiteFeature {
  id          String  @id @default(uuid())
  site_id     String
  feature_key String
  enabled     Boolean @default(false)

  site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([site_id, feature_key])
}

model ProfitCentre {
  id         String                @id @default(uuid())
  site_id    String
  name       String
  type       String? // legacy free-text; superseded by `category` (kept for non-destructive add)
  category   ProfitCentreCategory? // typed business unit (nullable so the add is non-destructive)
  is_active  Boolean               @default(true)
  created_at DateTime              @default(now())

  site      Site      @relation(fields: [site_id], references: [id], onDelete: Cascade)
  job_cards JobCard[]
  bookings  Booking[]

  @@index([site_id])
}

model Resource {
  id            String       @id @default(uuid())
  site_id       String // belongs to a Site (Location); operational tree is Group → Site → Resource
  name          String // e.g. "Lift 2"
  type          ResourceType // lift / mot_bay / spray_booth
  display_order Int          @default(0) // diary column ordering
  colour        String? // curated palette hex (e.g. "#3B82F6"); null → default neutral
  is_active     Boolean      @default(true)
  created_at    DateTime     @default(now())

  site        Site        @relation(fields: [site_id], references: [id], onDelete: Cascade)
  job_cards   JobCard[]
  diary_notes DiaryNote[]

  @@index([site_id])
}

// Many-to-many: which Site(s) a User is assigned to. Assignment only (no roles/enforcement yet).
// User.site_id remains the user's single active/default site; this is the broader assignment set.
model UserSite {
  user_id String
  site_id String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@id([user_id, site_id])
  @@index([site_id])
}

model Role {
  id          String  @id @default(uuid())
  group_id    String
  name        String
  description String?
  permissions Json    @default("{}")

  group Group  @relation(fields: [group_id], references: [id], onDelete: Cascade)
  users User[]

  @@index([group_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// Identity
// ───────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(STANDARD)

  // --- FIXED GREASEDESK FIELDS ---
  // Optional at creation time; enforced in app layer when linking staff.
  group_id        String?
  site_id         String?
  primary_site_id String? // admin-set landing/default site (must be one of the user's assigned sites)
  role_id         String?
  is_active       Boolean  @default(true)
  is_owner        Boolean  @default(false) // immutable: marks the one primary-subscriber per group
  // Per-user grant (ADMIN-set, off by default): a trusted STANDARD mechanic may RAISE an invoice
  // (in_progress→invoiced) at an assigned site, without being promoted to SITE_MANAGER. Grants ONLY
  // the issue transition + retail price visibility — NOT mark-paid, NOT unlock (ADMIN), NOT margin.
  can_invoice     Boolean  @default(false)
  created_at      DateTime @default(now())

  // --- INVITE / SET-PASSWORD TOKEN (single-use; SHA-256 of a high-entropy random token) ---
  invite_token_hash    String?
  invite_token_expires DateTime?
  invite_token_used_at DateTime?

  // --- PASSWORD RESET TOKEN — DELIBERATELY SEPARATE from the invite token (ruling 2026-07-18).
  // Different semantics: an invite is single-use-and-dead; a reset is legitimately REPEATABLE.
  // Reusing invite_* would inherit its "already been used" messaging and the 409-on-existing-email
  // behaviour. 1-hour expiry; consumed (nulled) on a successful reset; only the SHA-256 is stored.
  reset_token_hash    String?
  reset_token_expires DateTime?
  // Session revocation floor. The auth strategy is JWT (self-contained, NOT revocable by deleting
  // rows — the Session table is vestigial under strategy:'jwt'), so a stolen 90-day cookie would
  // otherwise outlive a password reset. Set to now() on reset, on a password change, on an ADMIN
  // "sign out all devices", and on deactivation. The jwt callback kills any token whose `authAt`
  // (our own stamp — NextAuth's `iat` is not reliably exposed there) predates it.
  // THE one place a session is invalidated server-side.
  sessions_valid_from DateTime?

  // Deactivation timestamp. SPLITS THE TWO MEANINGS of is_active=false, which otherwise conflates
  // "invited, never accepted" with "suspended by an admin" — the roster's badge reads the first and
  // would mislabel the second. is_active stays THE enforcement flag (login checks it, nothing else
  // changes); this column only says WHICH kind of inactive, and when. Null + inactive = pending
  // invite; set + inactive = deactivated. WHO did it lives in the audit trail, not here.
  deactivated_at DateTime?

  // --- PROFILE FIELDS (all optional; name + email above are the existing identity fields) ---
  job_title                  String?
  start_date                 DateTime? @db.Date
  phone                      String?
  address                    String?
  driving_licence_categories String?
  next_of_kin_name           String?
  next_of_kin_relationship   String?
  next_of_kin_phone          String?
  emergency_note             String? // voluntary safety note — visible to admin/owner + the user only
  certifications             String?
  working_hours              String?

  // +++ CUSTOMER PORTAL LINK ---
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // --- RELATIONS ---
  group            Group?         @relation(fields: [group_id], references: [id], onDelete: SetNull)
  site             Site?          @relation(fields: [site_id], references: [id], onDelete: SetNull)
  staffRole        Role?          @relation(fields: [role_id], references: [id], onDelete: Restrict)
  site_assignments UserSite[]
  job_cards        JobCard[]      @relation("JobCardMechanic")
  audit_logs       AuditLog[]
  job_card_photos  JobCardPhoto[] @relation("JobCardPhotoUploader")
  cost_person      CostPerson? // optional future link — costs ≠ logins

  // --- NEXTAUTH ---
  accounts Account[]
  sessions Session[]

  @@index([group_id])
  @@index([site_id])
  @@index([role_id])
}

model Customer {
  id         String   @id @default(uuid())
  group_id   String
  // ORIGIN site, not ownership. A customer belongs to the GARAGE (group_id above), not to a bay —
  // so this is NULLABLE + SetNull, mirroring User.site_id. Previously it was required + Cascade,
  // which meant deleting a Location would have destroyed its customers AND their VehicleOwnership
  // edges (which cascade from Customer) — the spine of the car-first model. Only the application-
  // level delete guard stood in the way; invoices had DB-level protection and customers did not.
  // Null = the origin site is gone; the customer survives as a group-level record.
  site_id    String?
  name       String
  phone      String?
  email      String?
  address    String? // billing address — source for Invoice.customer_address_snapshot
  notes      String?
  created_at DateTime @default(now())

  // +++ CUSTOMER PORTAL LINK ---
  userId String? @unique
  user   User?

  // --- RELATIONS ---
  group      Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site       Site?              @relation(fields: [site_id], references: [id], onDelete: SetNull)
  vehicles   Vehicle[]
  ownerships VehicleOwnership[]
  bookings   Booking[]
  job_cards  JobCard[]

  @@index([group_id, site_id])
}

model Vehicle {
  id                      String    @id @default(uuid())
  group_id                String
  customer_id             String? // WELD retired (Stage C): nullable + SetNull + unwritten. Owner source is the ownership edge.
  // Car-first re-root (Stage A, additive). identity_id links to the stable VIN-soft-anchored
  // VehicleIdentity (1:1 now, mergeable cross-tenant later). vin_normalized is the canonical
  // dedup key (upper/strip). Ownership moves to the VehicleOwnership edge — customer_id above
  // stays required through Stage A/B and is retired last.
  identity_id             String?
  vin_normalized          String?
  registration            String
  // Canonical match key (uppercase, non-alphanumeric stripped) so "BK69 YAV" / "bk69yav" resolve to
  // ONE vehicle — mirrors vin_normalized. find-or-create + reg lookup compare on this, never the raw.
  registration_normalized String?
  vin                     String?
  make                    String?
  model                   String? // NOT in free DVLA VES — captured manually
  derivative              String?
  colour                  String? // DVLA VES
  fuel_type               String? // DVLA VES (fuelType)
  transmission            String?
  engine_code             String?
  engine_cc               Int? // DVLA VES engine capacity (cc) — also the seed for a future auto-tier hook
  year                    Int? // DVLA VES (yearOfManufacture)
  // DVSA MOT History — captured for the banked service-reminder feature (mot_expiry) + mileage trend.
  mot_expiry              DateTime? @db.Date
  last_mot_mileage        Int?
  last_mot_date           DateTime? @db.Date
  mileage_at_create       Int?
  created_at              DateTime  @default(now())

  group      Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  customer   Customer?          @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  identity   VehicleIdentity?   @relation(fields: [identity_id], references: [id], onDelete: SetNull)
  ownerships VehicleOwnership[]
  bookings   Booking[]
  job_cards  JobCard[]

  @@index([group_id, customer_id])
  @@index([registration])
  @@index([identity_id])
  @@index([group_id, vin_normalized])
  @@index([group_id, registration_normalized])
}

// Car-first re-root: the stable, VIN-soft-anchored identity underneath a Vehicle. Tenant-scoped
// NOW (group_id) but shaped to go cross-tenant later WITHOUT a re-root — a future migration merges
// identities sharing a VIN across tenants by re-pointing Vehicle.identity_id. VIN is the PREFERRED
// anchor when present (unique per tenant), reg is the fallback, the uuid id is the anchor underneath.
model VehicleIdentity {
  id             String   @id @default(uuid())
  group_id       String
  vin_normalized String? // canonical VIN (upper/strip); NULL when no VIN captured yet
  registration   String? // reg fallback (regs recycle → not unique)
  created_at     DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@unique([group_id, vin_normalized]) // VIN unique PER TENANT when present (NULLs distinct)
  @@index([group_id, registration])
}

// Ownership as a time-bounded EDGE (not a column). Current owner = the row with is_current = true
// (one per vehicle, enforced by a partial-unique index added in raw SQL). Owner history = all rows.
// This is the seam a future garage-mediated transfer will use (close current edge, open a new one);
// no transfer mechanism is built here. PII stays on Customer — this edge only references it.
model VehicleOwnership {
  id          String    @id @default(uuid())
  vehicle_id  String
  customer_id String
  is_current  Boolean   @default(true)
  valid_from  DateTime  @default(now())
  valid_to    DateTime? // NULL = current; set on a future transfer
  created_at  DateTime  @default(now())

  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([vehicle_id])
  @@index([customer_id])
  @@index([vehicle_id, is_current])
}

model ServiceCatalogue {
  id                       String   @id @default(uuid())
  group_id                 String
  site_id                  String?
  service_code             String?
  name                     String
  description              String?
  default_duration_minutes Int?
  default_labour_rate      Decimal? @db.Decimal(12, 2)
  default_price            Decimal? @db.Decimal(12, 2)
  vat_rate                 Decimal? @default(20.00) @db.Decimal(5, 2)
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site     Site?     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([group_id, site_id])
}

model PartCatalogue {
  id          String   @id @default(uuid())
  group_id    String
  part_number String
  description String?
  brand       String?
  cost_price  Decimal? @db.Decimal(12, 2)
  sell_price  Decimal? @db.Decimal(12, 2)
  vat_rate    Decimal? @default(20.00) @db.Decimal(5, 2)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id, part_number])
}

model TaxRate {
  id         String    @id @default(uuid())
  group_id   String
  name       String?
  percentage Decimal   @db.Decimal(5, 2)
  valid_from DateTime
  valid_to   DateTime?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id])
}

model Booking {
  id               String    @id @default(uuid())
  group_id         String
  site_id          String
  profit_centre_id String? // reporting tag (optional); operational link is site_id (+ resource, later)
  customer_id      String?
  vehicle_id       String
  booking_date     DateTime
  start_time       DateTime?
  end_time         DateTime?
  service_id       String?
  resource_id      String?
  resource_type    String?
  status           String    @default("booked")
  created_at       DateTime  @default(now())

  group         Group             @relation(fields: [group_id], references: [id], onDelete: NoAction)
  site          Site              @relation(fields: [site_id], references: [id], onDelete: NoAction)
  profit_centre ProfitCentre?     @relation(fields: [profit_centre_id], references: [id], onDelete: NoAction)
  customer      Customer?         @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  vehicle       Vehicle           @relation(fields: [vehicle_id], references: [id], onDelete: NoAction)
  service       ServiceCatalogue? @relation(fields: [service_id], references: [id], onDelete: SetNull)

  @@index([group_id, site_id, profit_centre_id, customer_id, vehicle_id])
}

model JobCard {
  // PROVENANCE: created by the Invoice Import wizard rather than lived through the workshop.
  // Imported cards are excluded from the unpaid-invoice chaser and marked on dashboard periods.
  is_imported     Boolean @default(false)
  import_batch_id String?
  id                     String        @id @default(uuid())
  group_id               String
  site_id                String
  profit_centre_id       String? // reporting tag (optional); operational link is site_id (+ resource, later)
  customer_id            String?
  vehicle_id             String
  status                 JobCardStatus @default(draft)
  mechanic_assigned_id   String?
  odometer_in            Int?
  odometer_out           Int?
  labour_bill_numeric    Decimal?      @default(0) @db.Decimal(12, 2)
  labour_cost_numeric    Decimal?      @default(0) @db.Decimal(12, 2)
  parts_bill_numeric     Decimal?      @default(0) @db.Decimal(12, 2)
  parts_cost_numeric     Decimal?      @default(0) @db.Decimal(12, 2)
  vat_rate               Decimal       @default(20) @db.Decimal(5, 2) // per-quote VAT rate (editable, 0–100)
  completed_at           DateTime?
  archived_at            DateTime?
  signed_off_by_customer Boolean       @default(false)
  signed_off_at          DateTime?
  created_at             DateTime      @default(now())

  // --- SLICE 1: flags (main tab) ---
  flag_urgent       Boolean @default(false) // Urgent / Priority
  flag_sales_car    Boolean @default(false)
  flag_customer_car Boolean @default(false)
  flag_mot          Boolean @default(false) // MOT bay needed
  flag_diag         Boolean @default(false) // Diagnostic
  // Warranty / comeback: work redone free (a job came back). REAL cost (parts/labour still on the
  // estimate) but ZERO revenue — reporting reads revenue as 0 when set, cost unchanged. Faithful margin.
  is_comeback       Boolean @default(false)

  // --- SLICE 1: four-stage status (each Pending=false / Done=true) ---
  stage_details_done     Boolean @default(false) // 1. Job Card (details/estimate)
  stage_intake_done      Boolean @default(false) // 2. Intake Photos
  stage_injob_done       Boolean @default(false) // 3. In-Job
  stage_complete_done    Boolean @default(false) // 4. Complete Photos
  // Photo stages are SOFT gates: complete OR skipped advances the spine (capture can't be enforced).
  // A skip is a first-class audited event (actor + timestamp + optional reason in the audit diff).
  // Details has NO skip — it's a data gate, not a capture stage.
  stage_intake_skipped   Boolean @default(false)
  stage_injob_skipped    Boolean @default(false)
  stage_complete_skipped Boolean @default(false)

  // --- DIARY scheduling ---
  // start_at / end_at are the SOURCE OF TRUTH for scheduling (continuous time).
  held_on_lift             Boolean   @default(false) // job occupying a lift open-endedly (e.g. awaiting parts)
  garage_notes             String? // internal staff notes on the job
  resource_id              String?
  start_at                 DateTime? // scheduling start (source of truth)
  // Booking WORKING duration (minutes) — the occupancy-footprint SOURCE OF TRUTH. The footprint,
  // its per-day segments, and end_at are derived from (start_at + this + site hours) via lib/occupancy.
  booking_duration_minutes Int?
  end_at                   DateTime? // DERIVED convenience = footprint true wrapped end. Diary week-fetch bound +
  // display only; never source of truth (duration wins). Guard ignores it.
  // Legacy slot model — retained until retired in a later slice; no longer read.
  scheduled_date           DateTime? @db.Date
  start_slot               Int?
  end_slot                 Int?

  group             Group          @relation(fields: [group_id], references: [id], onDelete: NoAction)
  site              Site           @relation(fields: [site_id], references: [id], onDelete: NoAction)
  profit_centre     ProfitCentre?  @relation(fields: [profit_centre_id], references: [id], onDelete: NoAction)
  customer          Customer?      @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  vehicle           Vehicle        @relation(fields: [vehicle_id], references: [id], onDelete: NoAction)
  mechanic_assigned User?          @relation("JobCardMechanic", fields: [mechanic_assigned_id], references: [id], onDelete: SetNull)
  resource          Resource?      @relation(fields: [resource_id], references: [id], onDelete: SetNull)
  photos            JobCardPhoto[]
  items             JobCardItem[]
  invoice           Invoice?

  @@index([group_id, site_id, profit_centre_id, customer_id, vehicle_id])
  @@index([status])
  @@index([resource_id, scheduled_date])
  @@index([resource_id, start_at])
}

model JobCardPhoto {
  id               String   @id @default(uuid())
  job_card_id      String
  group_id         String? // TENANT partition (also the R2 key prefix) — garages never see each other's photos
  stage            String? // intake | injob | completion
  slot             String? // angle key (front/rear/…) | 'freeform' | 'damage'
  label            String? // free-text (damage note, e.g. "Scratch — nearside door")
  media_type       String? // 'photo' | 'video' — NULL means photo (pre-video rows; never backfilled)
  duration_seconds Int? // video length (client-probed metadata; display only)
  r2_key           String? // private R2 object key; display via presigned GET (URL never stored)
  poster_r2_key    String? // VIDEO ONLY: a small JPEG poster frame (captured client-side ~1-2s into
                           // the clip), its own R2 object. NULL = pre-poster video → placeholder tile.
  rotation         Int     @default(0) // 0/90/180/270 — a display INTERPRETATION applied as a CSS
                           // transform (grid + lightbox). NEVER re-encodes or rewrites the R2 bytes.
  photo_type       String?
  file_url         String? // legacy (pre-R2); nullable now
  uploaded_by      String?
  uploaded_at      DateTime @default(now())

  job_card JobCard @relation(fields: [job_card_id], references: [id], onDelete: Cascade)
  user     User?   @relation("JobCardPhotoUploader", fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@index([job_card_id])
  @@index([job_card_id, stage])
}

model JobCardItem {
  cost_basis String? // 'actual' | 'estimated' — provenance of unit_cost on an imported line
  id                String   @id @default(uuid())
  job_card_id       String
  item_type         ItemType
  description       String
  qty               Decimal  @default(1.00) @db.Decimal(12, 2)
  // NULLABLE (2026-07-17): null = trade cost UNKNOWN (ad-hoc part not yet catalogued); a number
  // (incl. 0 = genuinely free, e.g. a discount line) = known. The margin readers EXCLUDE null and
  // surface it — never silently count unknown as zero. The catalogue is the cost home.
  unit_cost         Decimal? @db.Decimal(12, 2)
  unit_price        Decimal  @default(0) @db.Decimal(12, 2)
  vat_rate          Decimal  @default(20.00) @db.Decimal(5, 2)
  vat_amount        Decimal  @default(0) @db.Decimal(12, 2)
  labour_hours      Decimal? @db.Decimal(6, 2) // fixed lines: inherited labour content; ad-hoc labour lines carry hours in qty
  labour_outsourced Boolean  @default(false) // inherited from the product at save — frozen per-line (re-flagging a product never rewrites history)
  created_at        DateTime @default(now())

  // Origin hook: which catalogue item pre-filled this line (for the future per-item margin lens).
  // SetNull so archiving/deleting the catalogue item never breaks a historic line.
  catalogue_item_id String?

  job_card  JobCard        @relation(fields: [job_card_id], references: [id], onDelete: Cascade)
  catalogue CatalogueItem? @relation(fields: [catalogue_item_id], references: [id], onDelete: SetNull)

  @@index([job_card_id])
  @@index([catalogue_item_id])
}

// Lightweight labelled diary entry — NOT a job card (no customer/vehicle/quote). A note may be
// lift-specific (resource_id set — occupies a lift visually) or day-level (resource_id null —
// a floating annotation like "Hugh at Drs"). Holidays/leave are a separate HR concern, not notes.
model DiaryNote {
  id          String   @id @default(uuid())
  group_id    String
  site_id     String
  resource_id String?
  title       String
  start_at    DateTime
  end_at      DateTime
  colour      String?
  created_by  String?
  created_at  DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site     Site      @relation(fields: [site_id], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resource_id], references: [id], onDelete: SetNull)

  @@index([site_id, start_at])
}

model AuditLog {
  id         String   @id @default(uuid())
  group_id   String
  user_id    String?
  entity     String
  entity_id  String
  action     String
  diff_json  Json?
  created_at DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([group_id])
  @@index([user_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// NextAuth models (standard)
// ───────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────────────────────────────────────
// Invoicing — GreaseDesk IS the primary VAT invoice (replaces Xero at issue). Numbers are minted
// once (assignInvoiceNumber) and rendered once (formatInvoiceNumber); freeze-on-paid = canEditInvoice.
// The header is SNAPSHOT at issue so later profile edits never rewrite history.
// ───────────────────────────────────────────────────────────────────────────────

model Invoice {
  // PROVENANCE. external_ref carries the ORIGINAL system's number (Xero) — the GreaseDesk series
  // is still minted normally and stays gapless; on imported invoices the UI shows external_ref as
  // the primary number with the GreaseDesk number secondary.
  is_imported  Boolean @default(false)
  external_ref String?
  cost_basis   String? // 'actual' | 'estimated' | 'mixed' — how the parts costs behind this were obtained
  id                      String        @id @default(uuid())
  group_id                String // tenantId
  job_card_id             String        @unique // one invoice per card; sticky number on re-issue
  site_id                 String
  status                  InvoiceStatus @default(issued)
  series                  InvoiceSeries @default(chargeable) // which counter minted sequence_value
  sequence_value          Int // monotonic counter value underneath the rendered number
  invoice_number          String? // rendered string; set at issue, sticky thereafter
  issued_at               DateTime      @default(now())
  date_issued             DateTime? // the DOCUMENT issue/billing date (defaults from mint; manager-editable, audited) — issued_at stays the mint attestation
  paid_at                 DateTime?
  date_paid               DateTime? // the DOCUMENT fact (defaults from mark-paid; manager-editable, audited) — paid_at stays the attestation
  payment_method_id       String? // how it was paid (grain for method reporting — banked tile)
  payment_method_snapshot String? // method name at mark-paid; renames never rewrite history
  confirm_due_at          DateTime? // paid_pending only: when the clearance window elapses (cron confirms then)
  receipt_sent_at         DateTime? // confirmation receipt delivered; null on a confirmed invoice = visibly "receipt not sent"

  // Header snapshot captured at ISSUE (resolved values — never rewritten by later profile edits).
  company_name_snapshot       String
  company_vat_number_snapshot String?
  company_address_snapshot    String?
  customer_name_snapshot      String
  customer_address_snapshot   String?
  vehicle_reg_snapshot        String?
  vehicle_desc_snapshot       String?
  vehicle_vin_snapshot        String?
  vehicle_mileage_snapshot    Int? // odometer_in at issue (falls back to mileage_at_create)
  vat_registered_at_issue     Boolean
  created_at                  DateTime @default(now())

  group          Group          @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site           Site           @relation(fields: [site_id], references: [id], onDelete: NoAction)
  job_card       JobCard        @relation(fields: [job_card_id], references: [id], onDelete: NoAction)
  lines          InvoiceLine[]
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id], onDelete: SetNull)

  @@unique([group_id, series, sequence_value]) // no duplicate sequence per tenant per series
  @@index([group_id])
  @@index([site_id])

  // THE DATABASE IS THE BACKSTOP against double-posting an imported invoice. commit.ts also
  // checks at runtime, but two concurrent commits could both pass that check and both write;
  // only a constraint makes it impossible. NULL external_ref is exempt (Postgres), so ordinary
  // GreaseDesk invoices are unaffected.
  @@unique([group_id, external_ref])

}

model InvoiceLine {
  cost_basis        String? // 'actual' | 'estimated' — provenance of unit_cost on an imported line
  id                String   @id @default(uuid())
  invoice_id        String
  description       String
  qty               Decimal  @default(1) @db.Decimal(12, 2)
  unit_price        Decimal  @default(0) @db.Decimal(12, 2)
  vat_rate          Decimal  @default(0) @db.Decimal(5, 2)
  line_vat          Decimal  @default(0) @db.Decimal(12, 2)
  line_total        Decimal  @default(0) @db.Decimal(12, 2) // EX-VAT (qty×unit_price); gross = line_total + line_vat
  // INTERNAL — margin only; NEVER rendered to the customer. NULLABLE (2026-07-17): null = cost
  // UNKNOWN (frozen from an un-catalogued ad-hoc part); a number (incl. 0 = free) = known. The P&L
  // EXCLUDES null from parts-cost and surfaces the exposure — never counts unknown as zero.
  unit_cost         Decimal? @db.Decimal(12, 2)
  labour_hours      Decimal? @db.Decimal(6, 2) // frozen labour-content grain (fixed-service lines)
  // Frozen classification (freeze-at-issue model): the ledger reads THESE, never the mutable card.
  // Nullable only for pre-backfill legacy rows; every new snapshot writes both.
  item_type         ItemType?
  labour_outsourced Boolean  @default(false)
  catalogue_item_id String? // forward hook; NO FK yet (no catalogue table) — added when catalogue lands
  position          Int      @default(0)
  created_at        DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
}

// OCR SHADOW RUN (2026-07-13, fortnight floor trial): one row per engine attempt on every
// slot='vin' photo, logged AFTER the outbox drains it. OFFERS NOTHING — no UI reads this table.
// The trial's one number: proportion of vin photos whose checksum-valid candidate MATCHED the
// VIN a human subsequently typed (join candidates → Vehicle.vin at analysis time).
model VinReadShadow {
  id                String   @id @default(uuid())
  group_id          String
  photo_id          String
  job_card_id       String
  engine            String // 'ocr' | 'haiku' | 'skipped' | 'error:<engine>'
  candidates        Json? // [{ c, valid, source: 'raw'|'normalised' }]
  checksum_valid    Boolean  @default(false) // any candidate passed lib/vin
  latency_ms        Int      @default(0)
  cost_microdollars Int? // engine cost estimate in µ$ (Vision flat ~1500; Haiku from usage)
  created_at        DateTime @default(now())

  @@index([photo_id])
  @@index([group_id, created_at])
}

model PaymentMethod {
  id         String           @id @default(uuid())
  group_id   String
  name       String
  behaviour  PaymentClearance @default(windowed)
  active     Boolean          @default(true)
  position   Int              @default(0)
  created_at DateTime         @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([group_id])
}

model InvoiceSequence {
  group_id            String   @id // one row per tenant
  last_value          Int      @default(0) // CHARGEABLE counter — monotonic, never resets, never reused. Seedable in settings ONLY while no chargeable invoice exists.
  warranty_last_value Int      @default(0) // WARRANTY counter — same guarantees, fully independent (a comeback never burns a chargeable number).
  updated_at          DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
}

// ───────────────────────────────────────────────────────────────────────────────
// Product catalogue — a grain-standardiser + data-entry accelerator (NOT stock control). Defined
// once per tenant (code → cost/price/VAT/type); typing the code on a job-card line pre-fills it as
// editable defaults. Carries BOTH cost and price so margin is banked at entry.
// ───────────────────────────────────────────────────────────────────────────────

model CatalogueItem {
  id                String   @id @default(uuid())
  group_id          String // TENANT-level — one shared catalogue, one price, across all sites
  code              String // required; unique per tenant; the match key
  // Human label shown in "choose a service" pickers (distinct from code=reference and the printed
  // spec). Backfilled = code for existing rows; consumers show `title || code` so it's never blank.
  title             String?
  name              String // fills the line's description on autocomplete
  item_type         ItemType // labour | part | misc | fixed
  // Simple items (part/labour/misc): flat cost + price. Fixed items: these are MIRRORED derived-on-
  // save from base_price_ex_vat + the component sum (see lib/catalogue.ts) — never set by callers.
  unit_cost         Decimal  @db.Decimal(12, 2)
  unit_price        Decimal  @db.Decimal(12, 2)
  vat_rate          Decimal  @default(20) @db.Decimal(5, 2) // defaulted from getTenantVat().defaultRate on create
  active            Boolean  @default(true) // archive (false) preferred over hard delete — preserves history
  // Fixed-price services only: the anchor/lowest-tier EX-VAT price (null for simple items).
  base_price_ex_vat Decimal? @db.Decimal(12, 2)
  // Notional labour CONTENT of a fixed-price service (charged hours). NOT booking duration, NOT
  // actual worked hours (clocking is banked). Inherited by each job line using the service.
  labour_hours      Decimal? @db.Decimal(6, 2)
  // Bought-in labour/services (MOT, Star clutch): cost of sale via components, marked up,
  // INVISIBLE to utilisation — labour_hours stays the CUSTOMER-BILLED hours (prices the job)
  // but never enters the charged-hours numerator or the missing-hours amber.
  labour_outsourced Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  group         Group                    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  job_lines     JobCardItem[]
  components    CatalogueComponent[]
  tier_prices   CatalogueItemTierPrice[]
  promo_targets PromoTarget[]

  @@unique([group_id, code])
  @@index([group_id])
  aliases CatalogueAlias[]
}

// Tenant-DEFINED, OPTIONAL vehicle/price tiers (0 tiers = single-price world; no tier UI shown).
model ServiceTier {
  id         String   @id @default(uuid())
  group_id   String
  name       String
  position   Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  group       Group                    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  tier_prices CatalogueItemTierPrice[]

  @@index([group_id])
}

// A fixed service's cost/spec components. NEVER a priced customer row — only descriptions
// concatenate into the invoice line's spec; qty×unit_cost feeds the item's true cost.
model CatalogueComponent {
  id                String  @id @default(uuid())
  catalogue_item_id String
  description       String
  qty               Decimal @default(1) @db.Decimal(12, 2)
  unit_cost_ex_vat  Decimal @default(0) @db.Decimal(12, 2)
  position          Int     @default(0)

  item CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)

  @@index([catalogue_item_id])
}

// Per-tier published price override. Three states: no row → inherit base_price; value → that price;
// null price_ex_vat → OFFERED at this tier but price set per-job (manual on the card picker).
model CatalogueItemTierPrice {
  id                String   @id @default(uuid())
  catalogue_item_id String
  tier_id           String
  price_ex_vat      Decimal? @db.Decimal(12, 2)

  item CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)
  tier ServiceTier   @relation(fields: [tier_id], references: [id], onDelete: Cascade)

  @@unique([catalogue_item_id, tier_id])
  @@index([catalogue_item_id])
  @@index([tier_id])
}

// Reusable discount codes ("promotions"). VAT-aware: `amount` is entered/advertised INC-VAT for a
// fixed promo (£ off) or is the percentage for a percentage promo. Applied on an estimate as ONE
// negative EX-VAT part line via the existing discount mechanism (the VAT split falls out of the
// aggregate recompute in lib/quote-totals). A promo is NOT sellable — its own section, not a product.
enum PromoType {
  fixed // amount = £ off, INC-VAT
  percentage // amount = percent off the inc-VAT total at apply-time
}

model Promo {
  id         String    @id @default(uuid())
  group_id   String // TENANT-level — one shared promo list across all sites
  code       String // short code / match key, unique per tenant (e.g. "BMW50")
  label      String // human label shown on the discount line ("10% off")
  promo_type PromoType
  amount     Decimal   @db.Decimal(12, 2) // fixed: £ inc-VAT; percentage: the percent (e.g. 10.00)
  active     Boolean   @default(true) // archive (false) preferred over delete — keeps history legible
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  group   Group         @relation(fields: [group_id], references: [id], onDelete: Cascade)
  targets PromoTarget[] // for a percentage promo: the catalogue items it applies to

  @@unique([group_id, code])
  @@index([group_id])
}

// A percentage promo's targeted products — the estimate matches these catalogue ids to job lines
// (via JobCardItem.catalogue_item_id) so the % discounts only the covered services, each keeping its
// own VAT treatment. Fixed-£ promos ignore targets (whole-job discount).
model PromoTarget {
  id                String @id @default(uuid())
  promo_id          String
  catalogue_item_id String

  promo Promo         @relation(fields: [promo_id], references: [id], onDelete: Cascade)
  item  CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)

  @@unique([promo_id, catalogue_item_id])
  @@index([promo_id])
  @@index([catalogue_item_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// Cost-capture (per-site P&L foundation) — raw grains only, no aggregation here.
// Every cost (person or overhead) is allocated across one+ sites by percent (Σ=100%).
// The 100%-sum + tenant-site invariant is enforced in lib/cost-allocation.ts (the one place).
// ───────────────────────────────────────────────────────────────────────────────

// Headcount = people-as-costs, independent of User (a temp/bottle-washer costs money without a
// login). Optional user_id links a cost to a real login later; costs ≠ logins.
model CostPerson {
  id             String   @id @default(uuid())
  group_id       String
  name           String
  role           String? // free-text ("Master Tech", "Bottle washer")
  cost_type      CostType
  amount_pennies Int // salary (annual) OR hourly rate, in pennies
  user_id        String?  @unique
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  // --- CAPACITY MODEL (utilisation denominator) ---
  // is_chargeable marks "turns spanners" — deliberately NOT User.role (a manager can be
  // chargeable) and default FALSE so non-productive staff never inflate capacity.
  // contracted_hours_per_day: NULL on a chargeable person = incomplete config (amber flag).
  // working_days: rostered weekdays (0=Sun..6=Sat); EMPTY = inherit the site's open_days
  // (TMBS default Mon–Sat) — an explicit value overrides.
  is_chargeable               Boolean   @default(false)
  contracted_hours_per_day    Decimal?  @db.Decimal(4, 2)
  working_days                Int[]     @default([])
  // Annual leave allowance in DAYS (per person, admin-editable). Leave-year = CALENDAR year in
  // v1: "taken" = this calendar year's leave rows, balance = allowance − taken. SEAM (banked):
  // configurable leave-year start + carry-over + part-time/six-day pro-rata would land here.
  // Allowance/balance are PER-PERSON figures — never apportioned or summed across sites.
  annual_leave_allowance_days Decimal?  @default(28.0) @db.Decimal(4, 1)
  // Utilisation factor (%): the REALISTIC share of this person's available hours that can
  // be billed — sets the workshop's derived target; NEVER an individual performance score.
  // NOT NULL (default 70 — a competent full-time mechanic) so the target can't break.
  // Effective-dated via EmploymentEvent kind `factor`; the TARGET resolves value-at-window-end
  // from the series (the first value-true-at-time read — historic months keep their factor).
  utilisation_factor          Int       @default(70)
  // Employment dates — RECORDED ONLY in v1, wired to no calculation. The anchor for banked:
  // auto pro-rata of the allowance from start_date, leaver handling, mid-month capacity proration.
  start_date                  DateTime?
  end_date                    DateTime?

  group            Group             @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [user_id], references: [id], onDelete: SetNull)
  allocations      CostAllocation[]
  leave            LeaveRecord[]
  employmentEvents EmploymentEvent[]

  @@index([group_id])
}

// --- Leave (capacity subtraction). PER-DAY rows by design: clean month attribution, no
// range-splitting math. hours NULL = the person's full rostered day at read time (stays correct
// if contracted hours later change); an explicit value = part-day (validated ≤ contracted).
// Leave only subtracts when the date is a ROSTERED day — a Sunday entry subtracts nothing.
// status defaults approved: the manager IS the write path in v1 (mechanic self-service
// request→approve is banked — adding a `requested` enum value + transitions is additive).
// Allowance rule lives in lib/leave-types DEDUCTS_ALLOWANCE (single source): only annual +
// closure consume the grant; the rest are capacity-affecting but allowance-neutral.
enum LeaveType {
  annual
  sick
  other
  closure // company-mandated closure (e.g. Christmas shutdown) — REAL pre-booked leave rows that
  // consume the allowance AND drop capacity (binding model: allowance = FULL grant;
  // closures are never modelled as a reduced allowance). Visually distinct in the Roster.
  compassionate
  parental
  training
}

enum LeaveStatus {
  approved
}

model LeaveRecord {
  id             String      @id @default(uuid())
  group_id       String
  cost_person_id String
  site_id        String // attribution site (a split-allocation mechanic's leave is booked where taken)
  date           DateTime // day-grained (UTC midnight)
  hours          Decimal?    @db.Decimal(4, 2) // NULL = full rostered day
  // Rows created in ONE range booking share a batch id — displayed/edited/deleted as one unit.
  // NULL = legacy/single ad-hoc row. Storage stays per-day (clean month/year attribution).
  leave_batch_id String?
  type           LeaveType   @default(annual)
  status         LeaveStatus @default(approved)
  created_by     String? // user id (audit convenience; writeAudit rows carry the trail)
  created_at     DateTime    @default(now())

  group       Group      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  cost_person CostPerson @relation(fields: [cost_person_id], references: [id], onDelete: Cascade)
  site        Site       @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([cost_person_id, date]) // one row per person-day (no double-subtraction)
  @@index([leave_batch_id])
  @@index([group_id, site_id, date])
}

// Manual public-holiday list (v1 — auto-derive from Site.locale banked). Group-scoped;
// site_id NULL = applies to ALL the group's sites (both TMBS sites share England & Wales
// bank holidays); set site_id for a region-specific site later. Subtracts a full rostered
// day from every chargeable mechanic whose roster includes that weekday.
// HR effective-dated employment history (RECORD-FIRST): the flat CostPerson columns stay the
// HEAD of each series and every compute keeps reading them; events are the append-only log.
// kind buckets one field-family each; value_json/previous_json carry {…} shaped per kind.
enum EmploymentEventKind {
  wage // { amount_pennies, cost_type }
  hours // { contracted_hours_per_day }
  pattern // { working_days } — 4e superseded: college windows = paired pattern events
  chargeable // { is_chargeable }
  allowance // { annual_leave_allowance_days }
  started // { start_date }
  ended // { end_date } — mark-as-left (is_active=false in the same tx)
  name // { name } — a surname change is HR history, not a silent overwrite
  factor // { utilisation_factor } — workshop expectation %, effective-dated (target reads value-at-time)
  role // { role } — the 80/20 of role progression (full position-management stays its own build)
}

model EmploymentEvent {
  id              String              @id @default(uuid())
  group_id        String
  cost_person_id  String
  kind            EmploymentEventKind
  // Admin-picked (defaults today; far-past/future needs an explicit confirm — never silent).
  // ORDERING ASSUMPTION for the banked value-true-at-time read: "value at T" = the latest event
  // of this kind with effective_date <= T (created_at breaks ties). Back-dating an event BEFORE
  // an existing one therefore INSERTS history — it governs only the gap up to the next event's
  // effective_date and never changes the head; the flat column remains current-state truth.
  effective_date  DateTime
  value_json      Json
  previous_json   Json?
  changed_by      String? // user id (the audit who; created_at is the when)
  created_at      DateTime            @default(now())
  // Corrections (admin-only, themselves recorded): a REDATE updates effective_date in place and
  // appends {at, by, from, to} here (array — repeat corrections stack); a VOID keeps the row
  // visible (struck through) but EXCLUDED from any value-at-time read — the ordering rule above
  // therefore reads "latest NON-VOIDED event of kind K with effective_date ≤ T".
  correction_json Json?
  voided_at       DateTime?
  voided_by       String?

  group       Group      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  cost_person CostPerson @relation(fields: [cost_person_id], references: [id], onDelete: Cascade)

  @@index([cost_person_id, kind, effective_date])
  @@index([group_id, created_at])
}

enum SiteConfigEventKind {
  open_days // { open_days: Int[] } — trading days; changing them changes HISTORICAL capacity
  hours // { open_hour, close_hour } — reserved; no event needed while times are unchanged
  breaks // { breaks } — reserved
}

// Effective-dated Site configuration — the EmploymentEvent pattern, applied to the site.
//
// WHY: open_days is a single current value, so every historical window was computed against
// TODAY's trading pattern. Great Bridge traded Mon–Sat until 2026-04-01 and Mon–Fri after, which
// meant any pre-April period silently understated capacity for anyone inheriting the site pattern.
//
// The flat Site columns REMAIN current-state truth and the resolver's final fallback (exactly as
// CostPerson keeps its flat columns beside EmploymentEvent). This table records the CHANGES.
// One event at the change date represents BOTH eras: value_json after, previous_json before —
// see openDaysAtWindowEnd for the resolution rule.
model SiteConfigEvent {
  id              String              @id @default(uuid())
  group_id        String
  site_id         String
  kind            SiteConfigEventKind
  effective_date  DateTime
  value_json      Json
  previous_json   Json?
  changed_by      String? // user id (the audit who; created_at is the when)
  created_at      DateTime            @default(now())
  // Corrections, mirroring EmploymentEvent: a VOID keeps the row visible but EXCLUDED from any
  // value-at-time read; the resolver filters voided_at: null.
  correction_json Json?
  voided_at       DateTime?
  voided_by       String?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site  Site  @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@index([site_id, kind, effective_date])
  @@index([group_id, created_at])
}


// ═══════════════════════════════════════════════════════════════════════════════════════════════
// INVOICE IMPORT — staging. STAGING IS NEVER THE LEDGER.
// Uploaded PDFs parse into these tables and are edited here; only an explicit commit drives the
// app's OWN write paths (jobcard create -> place -> stages -> issueInvoiceForCard -> mark paid).
// There is no second write path into the ledger, and nothing here is read by any financial report.
// ═══════════════════════════════════════════════════════════════════════════════════════════════

enum ImportBatchStatus {
  open       // accepting uploads / in progress
  committing // whole-month commit under way
  committed  // every invoice resolved
  abandoned
}

enum StagedInvoiceStatus {
  pending     // parsed, untouched
  in_progress // being worked in the wizard (resumable across sessions)
  committed   // written to the ledger; job_card_id + invoice_id set
  skipped     // deliberately not imported; skip_reason required
}

model ImportBatch {
  id         String            @id @default(uuid())
  group_id   String
  site_id    String
  label      String // e.g. "TMBS May 2026"
  source     String            @default("xero_pdf")
  status     ImportBatchStatus @default(open)
  created_by String?
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  group    Group           @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site     Site            @relation(fields: [site_id], references: [id], onDelete: Cascade)
  invoices StagedInvoice[]

  @@index([group_id, status])
}

model StagedInvoice {
  id       String @id @default(uuid())
  batch_id String
  group_id String

  external_number String // the Xero number, e.g. 100002292 — carried to Invoice.external_ref
  issue_date      DateTime // the PRINTED date; immutable, never shifted
  registration    String?
  // Customer name as PARSED from the invoice's address block, then EDITABLE by the operator.
  // 24 of TMBS's 42 May invoices carry only a first name ("Angi - BG63APU"), which is too thin an
  // identity to create a customer from — so where the vehicle is new the operator types the full
  // name before commit. Where the registration matches an existing vehicle the customer comes from
  // the ownership edge and this is a CROSS-CHECK only. (No phone: 0/42 PDFs contain one.)
  customer_name   String?
  // RECONCILIATION IS A HARD COMMIT GATE: parsed line amounts must equal the printed Subtotal.
  subtotal_printed Decimal  @db.Decimal(12, 2)
  subtotal_parsed  Decimal  @db.Decimal(12, 2)
  reconciled       Boolean  @default(false)
  // VAT is COMPUTED through lib/tax.computeTax, never taken from the PDF. A variance is surfaced,
  // not absorbed — at least one May invoice carries a discount entered VAT-inclusive.
  vat_printed      Decimal? @db.Decimal(12, 2)
  // The printed GROSS. Captured at ingest so the post-commit assertion can compare what was WRITTEN
  // against all three printed figures, not just the subtotal the reconciliation gate checks.
  total_printed    Decimal? @db.Decimal(12, 2)
  vat_computed     Decimal? @db.Decimal(12, 2)

  // The diary date is EDITABLE per card and defaults to issue_date; the invoice keeps its printed
  // date immutably. Weekend-dated invoices are placed on a working day of the operator's choosing —
  // nothing is shifted automatically.
  planned_start_at DateTime?
  planned_resource_id String?
  // WORKING minutes for the diary placement. Was hardcoded to 60 at commit, so every imported card
  // occupied exactly one hour whatever the job — silently wrong occupancy on every commit, and a
  // contradiction of the duration-is-source-of-truth rule. Null falls back to the seeded suggestion.
  planned_working_minutes Int?

  status      StagedInvoiceStatus @default(pending)
  skip_reason String?
  wizard_step Int                 @default(1)

  job_card_id String? // set on commit
  invoice_id  String? // set on commit
  raw_text    String? @db.Text // the extracted layer, kept for audit of what was parsed

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  batch ImportBatch  @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  lines StagedLine[]

  @@unique([group_id, external_number])
  @@index([batch_id, status])
}

model StagedLine {
  id                String  @id @default(uuid())
  staged_invoice_id String
  position          Int

  description       String
  continuation_text String? @db.Text // verbatim; describes the operations actually performed
  qty               Decimal @db.Decimal(12, 4)
  unit_price        Decimal @db.Decimal(12, 4) // 4dp: Xero prints 133.3333
  vat_text          String? // "20%" | "No VAT" | blank — recorded, NOT trusted for tax
  amount            Decimal @db.Decimal(12, 2) // negatives arrive parenthesised: (1,537.37)

  // Operator-supplied, resolved from line memory where known.
  kind              ItemType? // labour | part | misc | fixed
  catalogue_item_id String?
  parts_cost        Decimal?  @db.Decimal(12, 2)
  labour_hours      Decimal?  @db.Decimal(6, 2)
  cost_basis        String? // 'actual' | 'estimated'
  is_adjustment     Boolean   @default(false) // negative line: cost 0.00, never prompts

  // ── SPLIT: a bundled line broken into its constituents ─────────────────────────────────────
  // "Supply and fit 2 x front wheel bearing" @ 2 x 133.3333 is parts AND labour in one figure.
  // Children carry the breakdown (a parts line with its own catalogue item, a labour line with
  // hours); the PARENT remains exactly as printed and is what reconciles to the Subtotal.
  //
  // HARD INVARIANT: sum(children.amount) == parent.amount, to the penny. Enforced when a split is
  // saved AND again at commit. The invoice the customer holds is the truth; a split may re-express
  // it but must never change it. Splitting is OPTIONAL — an unsplit line commits as itself.
  parent_line_id String?
  parent         StagedLine?  @relation("LineSplit", fields: [parent_line_id], references: [id], onDelete: Cascade)
  children       StagedLine[] @relation("LineSplit")

  staged_invoice StagedInvoice @relation(fields: [staged_invoice_id], references: [id], onDelete: Cascade)

  @@index([staged_invoice_id, position])
  @@index([parent_line_id])
}

// A split, remembered so it can be re-offered. Same key as CatalogueAlias (description +
// unit_price), and applied RETROACTIVELY across pending staged lines exactly as an alias is:
// deciding how to break a bundle down once settles every later occurrence in the batch.
model LineSplitTemplate {
  id            String   @id @default(uuid())
  group_id      String
  description   String
  unit_price    Decimal? @db.Decimal(12, 4)
  // [{ description, qty, unit_price, kind, catalogue_item_id, parts_cost, labour_hours }]
  children_json Json
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, description, unit_price])
}

// LINE MEMORY — the seed of the catalogue, not a throwaway import table.
// Keyed on description + unit_price because the SAME description at a different price is a
// DIFFERENT job (engine tiers: "Change Oil using 100% Synthetic engine oil" at 125 / 165 / 233.33).
// Aliasing lets differently-typed variants resolve to one canonical CatalogueItem.
model CatalogueAlias {
  id                String   @id @default(uuid())
  group_id          String
  catalogue_item_id String
  description       String
  unit_price        Decimal? @db.Decimal(12, 4) // null = matches at any price
  source            String   @default("import") // 'import' | 'manual'
  created_at        DateTime @default(now())

  group    Group         @relation(fields: [group_id], references: [id], onDelete: Cascade)
  item     CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)

  @@unique([group_id, description, unit_price])
  @@index([catalogue_item_id])
}

model PublicHoliday {
  id         String   @id @default(uuid())
  group_id   String
  site_id    String? // NULL = all sites
  date       DateTime // day-grained (UTC midnight)
  label      String
  created_at DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site  Site? @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([group_id, site_id, date])
  @@index([group_id, date])
}

// Open-ended, admin-extendable business costs (rent, rates, insurance, IT, phones…).
model Overhead {
  id                    String         @id @default(uuid())
  group_id              String
  name                  String
  ex_vat_amount_pennies Int // EX-VAT amount = the true cost, entered directly
  vat_rate              Decimal        @default(0) @db.Decimal(5, 2) // per-expense rate (free entry: 5, 0, 20…); pre-filled from Group.default_vat_rate
  period                OverheadPeriod
  is_active             Boolean        @default(true)
  created_at            DateTime       @default(now())

  group       Group            @relation(fields: [group_id], references: [id], onDelete: Cascade)
  allocations CostAllocation[]

  @@index([group_id])
}

// Shared allocation mechanism: one cost → many site allocations. Exactly one owner
// (cost_person_id XOR overhead_id) is enforced by a DB CHECK in the migration. Per-cost
// percents sum to 100.00 (basis-point validation in lib/cost-allocation.ts).
model CostAllocation {
  id             String   @id @default(uuid())
  group_id       String // denormalised tenant guard (indexed by-site pivot)
  site_id        String
  percent        Decimal  @db.Decimal(5, 2) // 0.01–100.00
  cost_person_id String?
  overhead_id    String?
  created_at     DateTime @default(now())

  group       Group       @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site        Site        @relation(fields: [site_id], references: [id], onDelete: Cascade)
  cost_person CostPerson? @relation(fields: [cost_person_id], references: [id], onDelete: Cascade)
  overhead    Overhead?   @relation(fields: [overhead_id], references: [id], onDelete: Cascade)

  @@unique([cost_person_id, site_id])
  @@unique([overhead_id, site_id])
  @@index([group_id])
  @@index([site_id])
  @@index([cost_person_id])
  @@index([overhead_id])
}

// Shared-state rate limiting for unauthenticated auth endpoints (forgot-password). Serverless has
// no usable in-memory state — invocations are cold and concurrent — and there's no Redis/KV in the
// stack, so the DB every request already touches IS the shared store. Append-only; counted over a
// window; pruned opportunistically. `key` is HASHED (email:<sha256>) so this never becomes a
// plaintext list of who asked for a reset. ip:<addr> keys are the second axis.
model AuthRateLimit {
  id         String   @id @default(uuid())
  key        String   // 'email:<sha256>' | 'ip:<addr>'
  created_at DateTime @default(now())

  @@index([key, created_at])
}
