// File: prisma/schema.prisma
// Last edited: 2025-11-18 15:10 Europe/London
// Notes:
// - Normalised whitespace (removed non-breaking spaces that can break prisma fmt).
// - Prices/taxes now use @db.Decimal(12,2) for consistent SQL types.
// - Kept your multi-tenant structure. Relation names preserved.
// - Safe defaults; no preview features required.

// ───────────────────────────────────────────────────────────────────────────────
// Generators & Datasource
// ───────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // Explicit binary targets so Prisma doesn't try to fetch a RHEL engine on Vercel
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────────
// Enums
// ───────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SITE_MANAGER
  STANDARD
}

// Job card lifecycle — stable lowercase keys; translated for display (never shown raw).
// Transitions + per-transition authority live in lib/jobcard-status.ts (the one place).
enum JobCardStatus {
  draft
  quoted
  accepted
  declined
  in_progress
  invoiced
  paid
  done
  cancelled
}

enum TenantStatus {
  trial
  active
  suspended
  cancelled
}

// Invoice lifecycle (bank-style). issued = number assigned, editable. paid_pending = attested
// paid, snapshot FROZEN, reversible in the clearance window, customer told NOTHING yet.
// paid = CONFIRMED by the clearance cron (receipt sent) — true settlement, the income grain.
enum InvoiceStatus {
  issued
  paid_pending
  paid
}

// Chargeable vs warranty invoices draw from SEPARATE counters — both independently gapless.
// A comeback must never burn a chargeable number.
enum InvoiceSeries {
  chargeable
  warranty
}

// Payment-method clearance behaviour: instant = no window (cash in the till); windowed = the
// tenant's clearance window then cron-confirm; manual = pending until explicitly confirmed
// (warranty companies / EMAC — external timescales, never auto-confirmed).
enum PaymentClearance {
  instant
  windowed
  manual
}

// Cost-capture (per-site P&L foundation). Raw cost grains only — no aggregation in-schema.
enum CostType {
  salary // amount_pennies = annual salary
  hourly // amount_pennies = hourly rate
}

enum OverheadPeriod {
  weekly
  monthly
  annual
}

enum BillingStatus {
  ok
  grace
  suspended
}

enum ItemType {
  labour
  part
  misc
  fixed // published fixed-price service bundle (price-led, cost-optional); its own estimate section
}

// Shared, system-defined category for a Profit Centre (typed business unit).
// Cross-site reporting slices by this. Add new values via migration as needed.
enum ProfitCentreCategory {
  repairs
  mot
  spraybooth
  car_sales
}

// Physical unit within a Profit Centre; these become the diary's columns.
enum ResourceType {
  lift
  mot_bay
  spray_booth
}

// ───────────────────────────────────────────────────────────────────────────────
// Core multi-tenant models
// ───────────────────────────────────────────────────────────────────────────────

model Group {
  id               String  @id @default(uuid())
  group_name       String
  trading_name     String?
  company_number   String?
  vat_number       String?
  // Master switch: VAT applies anywhere (quotes/invoices/overheads) only when true. Default true
  // preserves existing tenants' VAT-as-now behaviour; sub-threshold garages turn it off. Resolved
  // via lib/tenant-vat.ts and gated in computeQuoteTotals — never scattered.
  vat_registered   Boolean @default(true)
  // Company-wide default VAT rate (only meaningful when registered). THE single source that
  // cascades as an editable pre-fill to quotes + overheads. Read via lib/tenant-vat.ts.
  default_vat_rate Decimal @default(20) @db.Decimal(5, 2)
  address          String?

  // Invoice number DISPLAY format (per-tenant). Rendered via lib/invoice-number.ts::formatInvoiceNumber.
  // FY-prefix is a format string, never a reset. Padding default 4 (Xero-style "0001").
  invoice_prefix            String   @default("")
  invoice_pad_width         Int      @default(4)
  // Fiscal-year DISPLAY segment (e.g. INV-26-0042): 0 = off, 2 or 4 digits of the year the FY
  // started in. The counter underneath stays continuous — FY is formatting, never a reset.
  invoice_fy_digits         Int      @default(0)
  fy_start_month            Int      @default(4) // 1-12; UK default April
  // Warranty-series prefix (comeback £0 invoices) — the filter key for the future comebacks tile.
  invoice_warranty_prefix   String   @default("W")
  // "Sent with GreaseDesk" footer line in invoice EMAILS (never the PDF). Tiering policy later.
  invoice_email_footer      Boolean  @default(true)
  // Bank-style clearance window (hours): mark-paid holds reversible + silent this long before the
  // cron confirms and sends the receipt. Flat window; working-day-aware is a banked refinement.
  paid_confirm_window_hours Int      @default(24)
  // --- Invoicing tab settings (ADMIN; Settings → Invoicing) ---
  invoice_reply_to          String? // business Reply-To on invoice emails (fallback: billing_email)
  invoice_sender_name       String? // display name on the GreaseDesk-owned From (fallback: group_name)
  invoice_footer_text       String? // payment terms / footer block — multi-line, rendered on the document
  invoice_bcc               String? // garage-copy BCC (fallback: billing_email)
  logo_r2_key               String? // tenant logo in R2 ({group}/branding/…), top-centre of the PDF
  // Tax LABEL only (admin-typed: VAT/GST/Sales Tax…) — never derived from country; rate stays in Company Details.
  tax_label                 String   @default("VAT")
  billing_email             String   @unique
  is_franchise_grp          Boolean  @default(false)
  created_at                DateTime @default(now())

  // Human-facing, immutable account reference (GB-GD<n>), auto-assigned from a Postgres
  // sequence via a column default (atomic / collision-safe). Never updated by any API.
  ref           String       @unique @default(dbgenerated("('GB-GD' || nextval('group_ref_seq'::regclass))"))
  status        TenantStatus @default(trial) // tenant lifecycle (console-managed later)
  trial_ends_at DateTime? // set on signup to now + TRIAL_DAYS

  // --- Permission config (per-tenant admin toggles that relax STANDARD authority; default OFF).
  // Resolved via lib/permissions.ts and read inside the permission chokepoints — never scattered.
  perm_standard_edit_pricing  Boolean @default(false)
  perm_standard_diary_entries Boolean @default(false)
  // Diary financial visibility, per role (ADMIN/owner always sees both). see-values = per-block value +
  // "booked" total; see-margin = the margin total (exposes cost structure → tighter defaults).
  perm_manager_see_values     Boolean @default(true)
  perm_manager_see_margin     Boolean @default(true)
  perm_standard_see_values    Boolean @default(false)
  perm_standard_see_margin    Boolean @default(false)
  // Invoices view (AR/debtors surface, amounts included — the permission is binary by design).
  // Managers/admins always; this extends it to STANDARD.
  perm_standard_view_invoices Boolean @default(false)

  billing            GroupBilling?
  features           GroupFeature[]
  sites              Site[]
  roles              Role[]
  users              User[]
  customers          Customer[]
  vehicles           Vehicle[]
  vehicle_identities VehicleIdentity[]
  services           ServiceCatalogue[] // Services at Group level (master list)
  parts              PartCatalogue[]
  tax_rates          TaxRate[]
  promos             Promo[]
  payment_methods    PaymentMethod[]
  audit_logs         AuditLog[]
  bookings           Booking[]
  job_cards          JobCard[]
  diary_notes        DiaryNote[]

  // Cost-capture
  cost_people      CostPerson[]
  overheads        Overhead[]
  cost_allocations CostAllocation[]

  // Invoicing
  invoices         Invoice[]
  invoice_sequence InvoiceSequence?

  // Product catalogue (tenant-level; one shared catalogue across all sites)
  catalogue_items CatalogueItem[]
  service_tiers   ServiceTier[]
  leaveRecords    LeaveRecord[]
  publicHolidays  PublicHoliday[]
}

model GroupBilling {
  id               String        @id @default(uuid())
  group_id         String        @unique
  plan_name        String
  status           BillingStatus
  retention_months Int
  included_sites   Int
  active_sites_cnt Int           @default(1)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
}

model GroupFeature {
  id          String  @id @default(uuid())
  group_id    String
  feature_key String
  enabled     Boolean @default(false)

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, feature_key])
}

model Site {
  id             String   @id @default(uuid())
  group_id       String
  site_name      String
  trading_name   String?
  company_number String?
  vat_number     String?
  address        String?
  phone          String?
  email          String?
  timezone       String   @default("Europe/London")
  currency_code  String   @default("GBP")
  locale         String   @default("en-GB")
  is_franchise   Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  // --- NEW CONFIGURATION FIELDS ---
  pricing_display_mode String @default("ex_vat") // Ex VAT/Inc VAT display
  supported_countries  Json?
  supported_currencies Json?
  // --- DIARY DISPLAY (per-site) ---
  open_days            Int[]  @default([1, 2, 3, 4, 5, 6]) // weekdays open (0=Sun..6=Sat); default Mon–Sat
  open_hour            Int    @default(8) // diary window start hour
  close_hour           Int    @default(18) // diary window end hour
  week_start           Int    @default(1) // first day of week (0=Sun, 1=Mon)
  // Booking-form duration granularity (minutes) for the Quote-tab slot picker. Sub-day durations step
  // by this; working-day length comes from open_hour/close_hour. Default 30. Diary reads start_at/end_at.
  booking_slot_minutes Int    @default(30)
  // Non-working bands (lunch etc.) as [{start,end}] minutes-from-midnight. NULL/[] = none = current
  // behaviour. The footprint skips these; the diary draws them. Read via lib/occupancy parseBreaks.
  breaks               Json?
  // --------------------------------

  group            Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  features         SiteFeature[]
  profit_centres   ProfitCentre[]
  resources        Resource[]
  users            User[]
  user_assignments UserSite[]
  customers        Customer[]
  bookings         Booking[]
  job_cards        JobCard[]
  services         ServiceCatalogue[]
  diary_notes      DiaryNote[]
  cost_allocations CostAllocation[]
  invoices         Invoice[]
  leaveRecords     LeaveRecord[]
  publicHolidays   PublicHoliday[]

  @@index([group_id])
}

model SiteFeature {
  id          String  @id @default(uuid())
  site_id     String
  feature_key String
  enabled     Boolean @default(false)

  site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([site_id, feature_key])
}

model ProfitCentre {
  id         String                @id @default(uuid())
  site_id    String
  name       String
  type       String? // legacy free-text; superseded by `category` (kept for non-destructive add)
  category   ProfitCentreCategory? // typed business unit (nullable so the add is non-destructive)
  is_active  Boolean               @default(true)
  created_at DateTime              @default(now())

  site      Site      @relation(fields: [site_id], references: [id], onDelete: Cascade)
  job_cards JobCard[]
  bookings  Booking[]

  @@index([site_id])
}

model Resource {
  id            String       @id @default(uuid())
  site_id       String // belongs to a Site (Location); operational tree is Group → Site → Resource
  name          String // e.g. "Lift 2"
  type          ResourceType // lift / mot_bay / spray_booth
  display_order Int          @default(0) // diary column ordering
  colour        String? // curated palette hex (e.g. "#3B82F6"); null → default neutral
  is_active     Boolean      @default(true)
  created_at    DateTime     @default(now())

  site        Site        @relation(fields: [site_id], references: [id], onDelete: Cascade)
  job_cards   JobCard[]
  diary_notes DiaryNote[]

  @@index([site_id])
}

// Many-to-many: which Site(s) a User is assigned to. Assignment only (no roles/enforcement yet).
// User.site_id remains the user's single active/default site; this is the broader assignment set.
model UserSite {
  user_id String
  site_id String

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  site Site @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@id([user_id, site_id])
  @@index([site_id])
}

model Role {
  id          String  @id @default(uuid())
  group_id    String
  name        String
  description String?
  permissions Json    @default("{}")

  group Group  @relation(fields: [group_id], references: [id], onDelete: Cascade)
  users User[]

  @@index([group_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// Identity
// ───────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(STANDARD)

  // --- FIXED GREASEDESK FIELDS ---
  // Optional at creation time; enforced in app layer when linking staff.
  group_id        String?
  site_id         String?
  primary_site_id String? // admin-set landing/default site (must be one of the user's assigned sites)
  role_id         String?
  is_active       Boolean  @default(true)
  is_owner        Boolean  @default(false) // immutable: marks the one primary-subscriber per group
  created_at      DateTime @default(now())

  // --- INVITE / SET-PASSWORD TOKEN (single-use; SHA-256 of a high-entropy random token) ---
  invite_token_hash    String?
  invite_token_expires DateTime?
  invite_token_used_at DateTime?

  // --- PROFILE FIELDS (all optional; name + email above are the existing identity fields) ---
  job_title                  String?
  start_date                 DateTime? @db.Date
  phone                      String?
  address                    String?
  driving_licence_categories String?
  next_of_kin_name           String?
  next_of_kin_relationship   String?
  next_of_kin_phone          String?
  emergency_note             String? // voluntary safety note — visible to admin/owner + the user only
  certifications             String?
  working_hours              String?

  // +++ CUSTOMER PORTAL LINK ---
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // --- RELATIONS ---
  group            Group?         @relation(fields: [group_id], references: [id], onDelete: SetNull)
  site             Site?          @relation(fields: [site_id], references: [id], onDelete: SetNull)
  staffRole        Role?          @relation(fields: [role_id], references: [id], onDelete: Restrict)
  site_assignments UserSite[]
  job_cards        JobCard[]      @relation("JobCardMechanic")
  audit_logs       AuditLog[]
  job_card_photos  JobCardPhoto[] @relation("JobCardPhotoUploader")
  cost_person      CostPerson? // optional future link — costs ≠ logins

  // --- NEXTAUTH ---
  accounts Account[]
  sessions Session[]

  @@index([group_id])
  @@index([site_id])
  @@index([role_id])
}

model Customer {
  id         String   @id @default(uuid())
  group_id   String
  site_id    String
  name       String
  phone      String?
  email      String?
  address    String? // billing address — source for Invoice.customer_address_snapshot
  notes      String?
  created_at DateTime @default(now())

  // +++ CUSTOMER PORTAL LINK ---
  userId String? @unique
  user   User?

  // --- RELATIONS ---
  group      Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site       Site               @relation(fields: [site_id], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]
  ownerships VehicleOwnership[]
  bookings   Booking[]
  job_cards  JobCard[]

  @@index([group_id, site_id])
}

model Vehicle {
  id                      String    @id @default(uuid())
  group_id                String
  customer_id             String? // WELD retired (Stage C): nullable + SetNull + unwritten. Owner source is the ownership edge.
  // Car-first re-root (Stage A, additive). identity_id links to the stable VIN-soft-anchored
  // VehicleIdentity (1:1 now, mergeable cross-tenant later). vin_normalized is the canonical
  // dedup key (upper/strip). Ownership moves to the VehicleOwnership edge — customer_id above
  // stays required through Stage A/B and is retired last.
  identity_id             String?
  vin_normalized          String?
  registration            String
  // Canonical match key (uppercase, non-alphanumeric stripped) so "BK69 YAV" / "bk69yav" resolve to
  // ONE vehicle — mirrors vin_normalized. find-or-create + reg lookup compare on this, never the raw.
  registration_normalized String?
  vin                     String?
  make                    String?
  model                   String? // NOT in free DVLA VES — captured manually
  derivative              String?
  colour                  String? // DVLA VES
  fuel_type               String? // DVLA VES (fuelType)
  transmission            String?
  engine_code             String?
  engine_cc               Int? // DVLA VES engine capacity (cc) — also the seed for a future auto-tier hook
  year                    Int? // DVLA VES (yearOfManufacture)
  // DVSA MOT History — captured for the banked service-reminder feature (mot_expiry) + mileage trend.
  mot_expiry              DateTime? @db.Date
  last_mot_mileage        Int?
  last_mot_date           DateTime? @db.Date
  mileage_at_create       Int?
  created_at              DateTime  @default(now())

  group      Group              @relation(fields: [group_id], references: [id], onDelete: Cascade)
  customer   Customer?          @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  identity   VehicleIdentity?   @relation(fields: [identity_id], references: [id], onDelete: SetNull)
  ownerships VehicleOwnership[]
  bookings   Booking[]
  job_cards  JobCard[]

  @@index([group_id, customer_id])
  @@index([registration])
  @@index([identity_id])
  @@index([group_id, vin_normalized])
  @@index([group_id, registration_normalized])
}

// Car-first re-root: the stable, VIN-soft-anchored identity underneath a Vehicle. Tenant-scoped
// NOW (group_id) but shaped to go cross-tenant later WITHOUT a re-root — a future migration merges
// identities sharing a VIN across tenants by re-pointing Vehicle.identity_id. VIN is the PREFERRED
// anchor when present (unique per tenant), reg is the fallback, the uuid id is the anchor underneath.
model VehicleIdentity {
  id             String   @id @default(uuid())
  group_id       String
  vin_normalized String? // canonical VIN (upper/strip); NULL when no VIN captured yet
  registration   String? // reg fallback (regs recycle → not unique)
  created_at     DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@unique([group_id, vin_normalized]) // VIN unique PER TENANT when present (NULLs distinct)
  @@index([group_id, registration])
}

// Ownership as a time-bounded EDGE (not a column). Current owner = the row with is_current = true
// (one per vehicle, enforced by a partial-unique index added in raw SQL). Owner history = all rows.
// This is the seam a future garage-mediated transfer will use (close current edge, open a new one);
// no transfer mechanism is built here. PII stays on Customer — this edge only references it.
model VehicleOwnership {
  id          String    @id @default(uuid())
  vehicle_id  String
  customer_id String
  is_current  Boolean   @default(true)
  valid_from  DateTime  @default(now())
  valid_to    DateTime? // NULL = current; set on a future transfer
  created_at  DateTime  @default(now())

  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([vehicle_id])
  @@index([customer_id])
  @@index([vehicle_id, is_current])
}

model ServiceCatalogue {
  id                       String   @id @default(uuid())
  group_id                 String
  site_id                  String?
  service_code             String?
  name                     String
  description              String?
  default_duration_minutes Int?
  default_labour_rate      Decimal? @db.Decimal(12, 2)
  default_price            Decimal? @db.Decimal(12, 2)
  vat_rate                 Decimal? @default(20.00) @db.Decimal(5, 2)
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site     Site?     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([group_id, site_id])
}

model PartCatalogue {
  id          String   @id @default(uuid())
  group_id    String
  part_number String
  description String?
  brand       String?
  cost_price  Decimal? @db.Decimal(12, 2)
  sell_price  Decimal? @db.Decimal(12, 2)
  vat_rate    Decimal? @default(20.00) @db.Decimal(5, 2)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id, part_number])
}

model TaxRate {
  id         String    @id @default(uuid())
  group_id   String
  name       String?
  percentage Decimal   @db.Decimal(5, 2)
  valid_from DateTime
  valid_to   DateTime?

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@index([group_id])
}

model Booking {
  id               String    @id @default(uuid())
  group_id         String
  site_id          String
  profit_centre_id String? // reporting tag (optional); operational link is site_id (+ resource, later)
  customer_id      String?
  vehicle_id       String
  booking_date     DateTime
  start_time       DateTime?
  end_time         DateTime?
  service_id       String?
  resource_id      String?
  resource_type    String?
  status           String    @default("booked")
  created_at       DateTime  @default(now())

  group         Group             @relation(fields: [group_id], references: [id], onDelete: NoAction)
  site          Site              @relation(fields: [site_id], references: [id], onDelete: NoAction)
  profit_centre ProfitCentre?     @relation(fields: [profit_centre_id], references: [id], onDelete: NoAction)
  customer      Customer?         @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  vehicle       Vehicle           @relation(fields: [vehicle_id], references: [id], onDelete: NoAction)
  service       ServiceCatalogue? @relation(fields: [service_id], references: [id], onDelete: SetNull)

  @@index([group_id, site_id, profit_centre_id, customer_id, vehicle_id])
}

model JobCard {
  id                     String        @id @default(uuid())
  group_id               String
  site_id                String
  profit_centre_id       String? // reporting tag (optional); operational link is site_id (+ resource, later)
  customer_id            String?
  vehicle_id             String
  status                 JobCardStatus @default(draft)
  mechanic_assigned_id   String?
  odometer_in            Int?
  odometer_out           Int?
  labour_bill_numeric    Decimal?      @default(0) @db.Decimal(12, 2)
  labour_cost_numeric    Decimal?      @default(0) @db.Decimal(12, 2)
  parts_bill_numeric     Decimal?      @default(0) @db.Decimal(12, 2)
  parts_cost_numeric     Decimal?      @default(0) @db.Decimal(12, 2)
  vat_rate               Decimal       @default(20) @db.Decimal(5, 2) // per-quote VAT rate (editable, 0–100)
  completed_at           DateTime?
  archived_at            DateTime?
  signed_off_by_customer Boolean       @default(false)
  signed_off_at          DateTime?
  created_at             DateTime      @default(now())

  // --- SLICE 1: flags (main tab) ---
  flag_urgent       Boolean @default(false) // Urgent / Priority
  flag_sales_car    Boolean @default(false)
  flag_customer_car Boolean @default(false)
  flag_mot          Boolean @default(false) // MOT bay needed
  flag_diag         Boolean @default(false) // Diagnostic
  // Warranty / comeback: work redone free (a job came back). REAL cost (parts/labour still on the
  // estimate) but ZERO revenue — reporting reads revenue as 0 when set, cost unchanged. Faithful margin.
  is_comeback       Boolean @default(false)

  // --- SLICE 1: four-stage status (each Pending=false / Done=true) ---
  stage_details_done     Boolean @default(false) // 1. Job Card (details/estimate)
  stage_intake_done      Boolean @default(false) // 2. Intake Photos
  stage_injob_done       Boolean @default(false) // 3. In-Job
  stage_complete_done    Boolean @default(false) // 4. Complete Photos
  // Photo stages are SOFT gates: complete OR skipped advances the spine (capture can't be enforced).
  // A skip is a first-class audited event (actor + timestamp + optional reason in the audit diff).
  // Details has NO skip — it's a data gate, not a capture stage.
  stage_intake_skipped   Boolean @default(false)
  stage_injob_skipped    Boolean @default(false)
  stage_complete_skipped Boolean @default(false)

  // --- DIARY scheduling ---
  // start_at / end_at are the SOURCE OF TRUTH for scheduling (continuous time).
  held_on_lift             Boolean   @default(false) // job occupying a lift open-endedly (e.g. awaiting parts)
  garage_notes             String? // internal staff notes on the job
  resource_id              String?
  start_at                 DateTime? // scheduling start (source of truth)
  // Booking WORKING duration (minutes) — the occupancy-footprint SOURCE OF TRUTH. The footprint,
  // its per-day segments, and end_at are derived from (start_at + this + site hours) via lib/occupancy.
  booking_duration_minutes Int?
  end_at                   DateTime? // DERIVED convenience = footprint true wrapped end. Diary week-fetch bound +
  // display only; never source of truth (duration wins). Guard ignores it.
  // Legacy slot model — retained until retired in a later slice; no longer read.
  scheduled_date           DateTime? @db.Date
  start_slot               Int?
  end_slot                 Int?

  group             Group          @relation(fields: [group_id], references: [id], onDelete: NoAction)
  site              Site           @relation(fields: [site_id], references: [id], onDelete: NoAction)
  profit_centre     ProfitCentre?  @relation(fields: [profit_centre_id], references: [id], onDelete: NoAction)
  customer          Customer?      @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  vehicle           Vehicle        @relation(fields: [vehicle_id], references: [id], onDelete: NoAction)
  mechanic_assigned User?          @relation("JobCardMechanic", fields: [mechanic_assigned_id], references: [id], onDelete: SetNull)
  resource          Resource?      @relation(fields: [resource_id], references: [id], onDelete: SetNull)
  photos            JobCardPhoto[]
  items             JobCardItem[]
  invoice           Invoice?

  @@index([group_id, site_id, profit_centre_id, customer_id, vehicle_id])
  @@index([status])
  @@index([resource_id, scheduled_date])
  @@index([resource_id, start_at])
}

model JobCardPhoto {
  id               String   @id @default(uuid())
  job_card_id      String
  group_id         String? // TENANT partition (also the R2 key prefix) — garages never see each other's photos
  stage            String? // intake | injob | completion
  slot             String? // angle key (front/rear/…) | 'freeform' | 'damage'
  label            String? // free-text (damage note, e.g. "Scratch — nearside door")
  media_type       String? // 'photo' | 'video' — NULL means photo (pre-video rows; never backfilled)
  duration_seconds Int? // video length (client-probed metadata; display only)
  r2_key           String? // private R2 object key; display via presigned GET (URL never stored)
  photo_type       String?
  file_url         String? // legacy (pre-R2); nullable now
  uploaded_by      String?
  uploaded_at      DateTime @default(now())

  job_card JobCard @relation(fields: [job_card_id], references: [id], onDelete: Cascade)
  user     User?   @relation("JobCardPhotoUploader", fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@index([job_card_id])
  @@index([job_card_id, stage])
}

model JobCardItem {
  id           String   @id @default(uuid())
  job_card_id  String
  item_type    ItemType
  description  String
  qty          Decimal  @default(1.00) @db.Decimal(12, 2)
  unit_cost    Decimal  @default(0) @db.Decimal(12, 2)
  unit_price   Decimal  @default(0) @db.Decimal(12, 2)
  vat_rate     Decimal  @default(20.00) @db.Decimal(5, 2)
  vat_amount   Decimal  @default(0) @db.Decimal(12, 2)
  labour_hours Decimal? @db.Decimal(6, 2) // fixed lines: inherited labour content; ad-hoc labour lines carry hours in qty
  created_at   DateTime @default(now())

  // Origin hook: which catalogue item pre-filled this line (for the future per-item margin lens).
  // SetNull so archiving/deleting the catalogue item never breaks a historic line.
  catalogue_item_id String?

  job_card  JobCard        @relation(fields: [job_card_id], references: [id], onDelete: Cascade)
  catalogue CatalogueItem? @relation(fields: [catalogue_item_id], references: [id], onDelete: SetNull)

  @@index([job_card_id])
  @@index([catalogue_item_id])
}

// Lightweight labelled diary entry — NOT a job card (no customer/vehicle/quote). A note may be
// lift-specific (resource_id set — occupies a lift visually) or day-level (resource_id null —
// a floating annotation like "Hugh at Drs"). Holidays/leave are a separate HR concern, not notes.
model DiaryNote {
  id          String   @id @default(uuid())
  group_id    String
  site_id     String
  resource_id String?
  title       String
  start_at    DateTime
  end_at      DateTime
  colour      String?
  created_by  String?
  created_at  DateTime @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site     Site      @relation(fields: [site_id], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resource_id], references: [id], onDelete: SetNull)

  @@index([site_id, start_at])
}

model AuditLog {
  id         String   @id @default(uuid())
  group_id   String
  user_id    String?
  entity     String
  entity_id  String
  action     String
  diff_json  Json?
  created_at DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([group_id])
  @@index([user_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// NextAuth models (standard)
// ───────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────────────────────────────────────
// Invoicing — GreaseDesk IS the primary VAT invoice (replaces Xero at issue). Numbers are minted
// once (assignInvoiceNumber) and rendered once (formatInvoiceNumber); freeze-on-paid = canEditInvoice.
// The header is SNAPSHOT at issue so later profile edits never rewrite history.
// ───────────────────────────────────────────────────────────────────────────────

model Invoice {
  id                      String        @id @default(uuid())
  group_id                String // tenantId
  job_card_id             String        @unique // one invoice per card; sticky number on re-issue
  site_id                 String
  status                  InvoiceStatus @default(issued)
  series                  InvoiceSeries @default(chargeable) // which counter minted sequence_value
  sequence_value          Int // monotonic counter value underneath the rendered number
  invoice_number          String? // rendered string; set at issue, sticky thereafter
  issued_at               DateTime      @default(now())
  date_issued             DateTime? // the DOCUMENT issue/billing date (defaults from mint; manager-editable, audited) — issued_at stays the mint attestation
  paid_at                 DateTime?
  date_paid               DateTime? // the DOCUMENT fact (defaults from mark-paid; manager-editable, audited) — paid_at stays the attestation
  payment_method_id       String? // how it was paid (grain for method reporting — banked tile)
  payment_method_snapshot String? // method name at mark-paid; renames never rewrite history
  confirm_due_at          DateTime? // paid_pending only: when the clearance window elapses (cron confirms then)
  receipt_sent_at         DateTime? // confirmation receipt delivered; null on a confirmed invoice = visibly "receipt not sent"

  // Header snapshot captured at ISSUE (resolved values — never rewritten by later profile edits).
  company_name_snapshot       String
  company_vat_number_snapshot String?
  company_address_snapshot    String?
  customer_name_snapshot      String
  customer_address_snapshot   String?
  vehicle_reg_snapshot        String?
  vehicle_desc_snapshot       String?
  vehicle_vin_snapshot        String?
  vehicle_mileage_snapshot    Int? // odometer_in at issue (falls back to mileage_at_create)
  vat_registered_at_issue     Boolean
  created_at                  DateTime @default(now())

  group          Group          @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site           Site           @relation(fields: [site_id], references: [id], onDelete: NoAction)
  job_card       JobCard        @relation(fields: [job_card_id], references: [id], onDelete: NoAction)
  lines          InvoiceLine[]
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id], onDelete: SetNull)

  @@unique([group_id, series, sequence_value]) // no duplicate sequence per tenant per series
  @@index([group_id])
  @@index([site_id])
}

model InvoiceLine {
  id                String   @id @default(uuid())
  invoice_id        String
  description       String
  qty               Decimal  @default(1) @db.Decimal(12, 2)
  unit_price        Decimal  @default(0) @db.Decimal(12, 2)
  vat_rate          Decimal  @default(0) @db.Decimal(5, 2)
  line_vat          Decimal  @default(0) @db.Decimal(12, 2)
  line_total        Decimal  @default(0) @db.Decimal(12, 2) // EX-VAT (qty×unit_price); gross = line_total + line_vat
  unit_cost         Decimal  @default(0) @db.Decimal(12, 2) // INTERNAL — margin only; NEVER rendered to the customer
  labour_hours      Decimal? @db.Decimal(6, 2) // frozen labour-content grain (fixed-service lines)
  catalogue_item_id String? // forward hook; NO FK yet (no catalogue table) — added when catalogue lands
  position          Int      @default(0)
  created_at        DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@index([invoice_id])
}

model PaymentMethod {
  id         String           @id @default(uuid())
  group_id   String
  name       String
  behaviour  PaymentClearance @default(windowed)
  active     Boolean          @default(true)
  position   Int              @default(0)
  created_at DateTime         @default(now())

  group    Group     @relation(fields: [group_id], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([group_id])
}

model InvoiceSequence {
  group_id            String   @id // one row per tenant
  last_value          Int      @default(0) // CHARGEABLE counter — monotonic, never resets, never reused. Seedable in settings ONLY while no chargeable invoice exists.
  warranty_last_value Int      @default(0) // WARRANTY counter — same guarantees, fully independent (a comeback never burns a chargeable number).
  updated_at          DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
}

// ───────────────────────────────────────────────────────────────────────────────
// Product catalogue — a grain-standardiser + data-entry accelerator (NOT stock control). Defined
// once per tenant (code → cost/price/VAT/type); typing the code on a job-card line pre-fills it as
// editable defaults. Carries BOTH cost and price so margin is banked at entry.
// ───────────────────────────────────────────────────────────────────────────────

model CatalogueItem {
  id                String   @id @default(uuid())
  group_id          String // TENANT-level — one shared catalogue, one price, across all sites
  code              String // required; unique per tenant; the match key
  // Human label shown in "choose a service" pickers (distinct from code=reference and the printed
  // spec). Backfilled = code for existing rows; consumers show `title || code` so it's never blank.
  title             String?
  name              String // fills the line's description on autocomplete
  item_type         ItemType // labour | part | misc | fixed
  // Simple items (part/labour/misc): flat cost + price. Fixed items: these are MIRRORED derived-on-
  // save from base_price_ex_vat + the component sum (see lib/catalogue.ts) — never set by callers.
  unit_cost         Decimal  @db.Decimal(12, 2)
  unit_price        Decimal  @db.Decimal(12, 2)
  vat_rate          Decimal  @default(20) @db.Decimal(5, 2) // defaulted from getTenantVat().defaultRate on create
  active            Boolean  @default(true) // archive (false) preferred over hard delete — preserves history
  // Fixed-price services only: the anchor/lowest-tier EX-VAT price (null for simple items).
  base_price_ex_vat Decimal? @db.Decimal(12, 2)
  // Notional labour CONTENT of a fixed-price service (charged hours). NOT booking duration, NOT
  // actual worked hours (clocking is banked). Inherited by each job line using the service.
  labour_hours      Decimal? @db.Decimal(6, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  group         Group                    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  job_lines     JobCardItem[]
  components    CatalogueComponent[]
  tier_prices   CatalogueItemTierPrice[]
  promo_targets PromoTarget[]

  @@unique([group_id, code])
  @@index([group_id])
}

// Tenant-DEFINED, OPTIONAL vehicle/price tiers (0 tiers = single-price world; no tier UI shown).
model ServiceTier {
  id         String   @id @default(uuid())
  group_id   String
  name       String
  position   Int      @default(0)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  group       Group                    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  tier_prices CatalogueItemTierPrice[]

  @@index([group_id])
}

// A fixed service's cost/spec components. NEVER a priced customer row — only descriptions
// concatenate into the invoice line's spec; qty×unit_cost feeds the item's true cost.
model CatalogueComponent {
  id                String  @id @default(uuid())
  catalogue_item_id String
  description       String
  qty               Decimal @default(1) @db.Decimal(12, 2)
  unit_cost_ex_vat  Decimal @default(0) @db.Decimal(12, 2)
  position          Int     @default(0)

  item CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)

  @@index([catalogue_item_id])
}

// Per-tier published price override. Three states: no row → inherit base_price; value → that price;
// null price_ex_vat → OFFERED at this tier but price set per-job (manual on the card picker).
model CatalogueItemTierPrice {
  id                String   @id @default(uuid())
  catalogue_item_id String
  tier_id           String
  price_ex_vat      Decimal? @db.Decimal(12, 2)

  item CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)
  tier ServiceTier   @relation(fields: [tier_id], references: [id], onDelete: Cascade)

  @@unique([catalogue_item_id, tier_id])
  @@index([catalogue_item_id])
  @@index([tier_id])
}

// Reusable discount codes ("promotions"). VAT-aware: `amount` is entered/advertised INC-VAT for a
// fixed promo (£ off) or is the percentage for a percentage promo. Applied on an estimate as ONE
// negative EX-VAT part line via the existing discount mechanism (the VAT split falls out of the
// aggregate recompute in lib/quote-totals). A promo is NOT sellable — its own section, not a product.
enum PromoType {
  fixed // amount = £ off, INC-VAT
  percentage // amount = percent off the inc-VAT total at apply-time
}

model Promo {
  id         String    @id @default(uuid())
  group_id   String // TENANT-level — one shared promo list across all sites
  code       String // short code / match key, unique per tenant (e.g. "BMW50")
  label      String // human label shown on the discount line ("10% off")
  promo_type PromoType
  amount     Decimal   @db.Decimal(12, 2) // fixed: £ inc-VAT; percentage: the percent (e.g. 10.00)
  active     Boolean   @default(true) // archive (false) preferred over delete — keeps history legible
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  group   Group         @relation(fields: [group_id], references: [id], onDelete: Cascade)
  targets PromoTarget[] // for a percentage promo: the catalogue items it applies to

  @@unique([group_id, code])
  @@index([group_id])
}

// A percentage promo's targeted products — the estimate matches these catalogue ids to job lines
// (via JobCardItem.catalogue_item_id) so the % discounts only the covered services, each keeping its
// own VAT treatment. Fixed-£ promos ignore targets (whole-job discount).
model PromoTarget {
  id                String @id @default(uuid())
  promo_id          String
  catalogue_item_id String

  promo Promo         @relation(fields: [promo_id], references: [id], onDelete: Cascade)
  item  CatalogueItem @relation(fields: [catalogue_item_id], references: [id], onDelete: Cascade)

  @@unique([promo_id, catalogue_item_id])
  @@index([promo_id])
  @@index([catalogue_item_id])
}

// ───────────────────────────────────────────────────────────────────────────────
// Cost-capture (per-site P&L foundation) — raw grains only, no aggregation here.
// Every cost (person or overhead) is allocated across one+ sites by percent (Σ=100%).
// The 100%-sum + tenant-site invariant is enforced in lib/cost-allocation.ts (the one place).
// ───────────────────────────────────────────────────────────────────────────────

// Headcount = people-as-costs, independent of User (a temp/bottle-washer costs money without a
// login). Optional user_id links a cost to a real login later; costs ≠ logins.
model CostPerson {
  id             String   @id @default(uuid())
  group_id       String
  name           String
  role           String? // free-text ("Master Tech", "Bottle washer")
  cost_type      CostType
  amount_pennies Int // salary (annual) OR hourly rate, in pennies
  user_id        String?  @unique
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  // --- CAPACITY MODEL (utilisation denominator) ---
  // is_chargeable marks "turns spanners" — deliberately NOT User.role (a manager can be
  // chargeable) and default FALSE so non-productive staff never inflate capacity.
  // contracted_hours_per_day: NULL on a chargeable person = incomplete config (amber flag).
  // working_days: rostered weekdays (0=Sun..6=Sat); EMPTY = inherit the site's open_days
  // (TMBS default Mon–Sat) — an explicit value overrides.
  is_chargeable            Boolean  @default(false)
  contracted_hours_per_day Decimal? @db.Decimal(4, 2)
  working_days             Int[]    @default([])
  // Annual leave allowance in DAYS (per person, admin-editable). Leave-year = CALENDAR year in
  // v1: "taken" = this calendar year's leave rows, balance = allowance − taken. SEAM (banked):
  // configurable leave-year start + carry-over + part-time/six-day pro-rata would land here.
  // Allowance/balance are PER-PERSON figures — never apportioned or summed across sites.
  annual_leave_allowance_days Decimal? @default(28.0) @db.Decimal(4, 1)
  // Employment dates — RECORDED ONLY in v1, wired to no calculation. The anchor for banked:
  // auto pro-rata of the allowance from start_date, leaver handling, mid-month capacity proration.
  start_date DateTime?
  end_date   DateTime?

  group       Group            @relation(fields: [group_id], references: [id], onDelete: Cascade)
  user        User?            @relation(fields: [user_id], references: [id], onDelete: SetNull)
  allocations CostAllocation[]
  leave       LeaveRecord[]

  @@index([group_id])
}

// --- Leave (capacity subtraction). PER-DAY rows by design: clean month attribution, no
// range-splitting math. hours NULL = the person's full rostered day at read time (stays correct
// if contracted hours later change); an explicit value = part-day (validated ≤ contracted).
// Leave only subtracts when the date is a ROSTERED day — a Sunday entry subtracts nothing.
// status defaults approved: the manager IS the write path in v1 (mechanic self-service
// request→approve is banked — adding a `requested` enum value + transitions is additive).
enum LeaveType {
  annual
  sick
  other
  closure // company-mandated closure (e.g. Christmas shutdown) — REAL pre-booked leave rows that
          // consume the allowance AND drop capacity (binding model: allowance = FULL grant;
          // closures are never modelled as a reduced allowance). Visually distinct in the Roster.
}

enum LeaveStatus {
  approved
}

model LeaveRecord {
  id             String      @id @default(uuid())
  group_id       String
  cost_person_id String
  site_id        String // attribution site (a split-allocation mechanic's leave is booked where taken)
  date           DateTime // day-grained (UTC midnight)
  hours          Decimal?    @db.Decimal(4, 2) // NULL = full rostered day
  type           LeaveType   @default(annual)
  status         LeaveStatus @default(approved)
  created_by     String? // user id (audit convenience; writeAudit rows carry the trail)
  created_at     DateTime    @default(now())

  group       Group      @relation(fields: [group_id], references: [id], onDelete: Cascade)
  cost_person CostPerson @relation(fields: [cost_person_id], references: [id], onDelete: Cascade)
  site        Site       @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([cost_person_id, date]) // one row per person-day (no double-subtraction)
  @@index([group_id, site_id, date])
}

// Manual public-holiday list (v1 — auto-derive from Site.locale banked). Group-scoped;
// site_id NULL = applies to ALL the group's sites (both TMBS sites share England & Wales
// bank holidays); set site_id for a region-specific site later. Subtracts a full rostered
// day from every chargeable mechanic whose roster includes that weekday.
model PublicHoliday {
  id         String   @id @default(uuid())
  group_id   String
  site_id    String? // NULL = all sites
  date       DateTime // day-grained (UTC midnight)
  label      String
  created_at DateTime @default(now())

  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site  Site? @relation(fields: [site_id], references: [id], onDelete: Cascade)

  @@unique([group_id, site_id, date])
  @@index([group_id, date])
}

// Open-ended, admin-extendable business costs (rent, rates, insurance, IT, phones…).
model Overhead {
  id                    String         @id @default(uuid())
  group_id              String
  name                  String
  ex_vat_amount_pennies Int // EX-VAT amount = the true cost, entered directly
  vat_rate              Decimal        @default(0) @db.Decimal(5, 2) // per-expense rate (free entry: 5, 0, 20…); pre-filled from Group.default_vat_rate
  period                OverheadPeriod
  is_active             Boolean        @default(true)
  created_at            DateTime       @default(now())

  group       Group            @relation(fields: [group_id], references: [id], onDelete: Cascade)
  allocations CostAllocation[]

  @@index([group_id])
}

// Shared allocation mechanism: one cost → many site allocations. Exactly one owner
// (cost_person_id XOR overhead_id) is enforced by a DB CHECK in the migration. Per-cost
// percents sum to 100.00 (basis-point validation in lib/cost-allocation.ts).
model CostAllocation {
  id             String   @id @default(uuid())
  group_id       String // denormalised tenant guard (indexed by-site pivot)
  site_id        String
  percent        Decimal  @db.Decimal(5, 2) // 0.01–100.00
  cost_person_id String?
  overhead_id    String?
  created_at     DateTime @default(now())

  group       Group       @relation(fields: [group_id], references: [id], onDelete: Cascade)
  site        Site        @relation(fields: [site_id], references: [id], onDelete: Cascade)
  cost_person CostPerson? @relation(fields: [cost_person_id], references: [id], onDelete: Cascade)
  overhead    Overhead?   @relation(fields: [overhead_id], references: [id], onDelete: Cascade)

  @@unique([cost_person_id, site_id])
  @@unique([overhead_id, site_id])
  @@index([group_id])
  @@index([site_id])
  @@index([cost_person_id])
  @@index([overhead_id])
}
